{% extends "layout.html.j2" %}
{% from "icons.html.j2" import icon %}
{% block title %}Task Groups · Hashview{% endblock %}
{% block content %}

<div class="page-head">
    <div>
        <h1 class="page-title">Task Groups</h1>
        <div class="page-sub">// a set of tasks that can be assigned to a job</div>
    </div>
    <a class="btn btn-primary" href="{{ url_for('task_groups.task_groups_add') }}">{{ icon('plus', size=15) }} New Task Group</a>
</div>

<div class="card">
    {% if task_groups %}
    <table class="tbl">
        <thead>
            <tr>
                <th>Task Group Name</th>
                <th>Owner</th>
                <th class="center" style="width:140px;">Control</th>
            </tr>
        </thead>
        <tbody>
            {% for task_group in task_groups %}
            <tr>
                <td style="font-weight:500;">{{ task_group.name }}</td>
                <td style="color:var(--text-dim);">
                    {% for user in users %}
                        {% if user.id == task_group.owner_id %}
                            {{ user.first_name }} {{ user.last_name }}
                        {% endif %}
                    {% endfor %}
                </td>
                <td class="center">
                    <div style="display:flex; gap:4px; justify-content:center;">
                        <button type="button" class="icon-btn" title="Info" onclick="document.getElementById('info-{{ task_group.id }}').showModal()">{{ icon('info', size=15) }}</button>
                        <a class="icon-btn" href="/task_groups/assigned_tasks/{{ task_group.id }}" title="Assign Tasks">{{ icon('edit', size=15) }}</a>
                        <button type="button" class="icon-btn act-del" title="Delete" onclick="document.getElementById('del-{{ task_group.id }}').showModal()">{{ icon('trash', size=15) }}</button>
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <div class="card-body" style="text-align:center; padding:48px 24px;">
        <div class="mono" style="color:var(--text-dim); margin-bottom:14px;">No task groups found.</div>
        <a class="btn btn-primary" href="{{ url_for('task_groups.task_groups_add') }}">{{ icon('plus', size=15) }} Create a New Task Group</a>
    </div>
    {% endif %}
</div>

{# ---- per-task-group modals (native <dialog>, no framework) ---- #}
{% for task_group in task_groups %}
<dialog class="hv-dialog" id="info-{{ task_group.id }}">
    <div class="hv-dialog-head"><h3>Info: {{ task_group.name }}</h3><button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button></div>
    <div class="hv-dialog-body">
        <dl class="kv">
            <dt>Associated Tasks</dt>
            <dd>
                {% for task_group_task_entry in task_group.tasks.split(',') %}
                    <!-- So hacky -->
                    <!-- Now you may ask your self, why does the first comparison use strings, but the others use ints.... i dont know but it works -->
                    {% for task in tasks %}
                        {% if '[' in task_group_task_entry %}
                            {% if task.id|string() == task_group_task_entry.split('[')[1] %}
                                {{ task.name }} <br>
                            {% endif %}
                        {% endif %}
                        {% if ']' in task_group_task_entry %}
                            {% if task.id|int() == task_group_task_entry.split(']')[0]|int() %}
                                {{ task.name }} <br>
                            {% endif %}
                        {% endif %}
                        {% if task.id|int() == task_group_task_entry|int() %}
                            {{ task.name }} <br>
                        {% endif %}
                    {% endfor %}
                {% endfor %}
            </dd>
        </dl>
    </div>
    <div class="hv-dialog-foot"><button class="btn" onclick="this.closest('dialog').close()">Close</button></div>
</dialog>

<dialog class="hv-dialog" id="del-{{ task_group.id }}">
    <div class="hv-dialog-head"><h3>Delete {{ task_group.name }}?</h3><button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button></div>
    <div class="hv-dialog-body">This will permanently delete the task group. Note, the associated tasks will not be removed, only the group. Are you sure you want to continue?</div>
    <div class="hv-dialog-foot">
        <button class="btn" onclick="this.closest('dialog').close()">Back</button>
        <form action="/task_groups/delete/{{ task_group.id }}" method="POST" style="display:inline;">
            <button class="btn btn-danger" type="submit">Delete</button>
        </form>
    </div>
</dialog>
{% endfor %}

{% endblock content %}
