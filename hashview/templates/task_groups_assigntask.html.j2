{% extends "layout.html.j2" %}
{% from "icons.html.j2" import icon %}
{% block title %}Assign Tasks · Hashview{% endblock %}
{% block content %}

<div class="page-head">
    <div>
        <h1 class="page-title">Assign Tasks</h1>
        <div class="page-sub">// {{ task_group.name }} · each task runs once in the order selected</div>
    </div>
    <a class="btn btn-primary" href="{{ url_for('task_groups.task_groups_list') }}" role="button">{{ icon('check', size=15) }} Done</a>
</div>

<div class="grid" style="grid-template-columns: 1fr 1fr; align-items: start;">

    {# ============ Task Library ============ #}
    <div class="card" style="overflow: visible;">
        <div class="card-head">
            {{ icon('book', size=16) }}
            <h3>Task Library</h3>
        </div>
        <div class="card-body" style="overflow: visible;">
            <div class="page-sub" style="margin-bottom: 14px;">
                {{ icon('info', size=13) }} Add tasks to this group. Each task runs once in the order selected. Create new tasks from the Tasks menu.
            </div>

            <details style="position:relative;">
                <summary class="btn btn-primary" style="list-style:none; cursor:pointer;">
                    {{ icon('plus', size=15) }} Add Task
                </summary>
                <div class="card" style="margin-top:8px; max-height:300px; overflow-y:auto;">
                    <div class="card-body" style="padding:6px;">
                        {% for task in tasks %}
                            <a class="btn btn-ghost btn-block" style="justify-content:flex-start;" href="/task_groups/assigned_tasks/{{task_group.id}}/add_task/{{task.id}}">{{ icon('task', size=14) }} {{task.name}}</a>
                        {% else %}
                            <div class="page-sub" style="padding:8px 10px;">No tasks available.</div>
                        {% endfor %}
                    </div>
                </div>
            </details>
        </div>
    </div>

    {# ============ Assigned Tasks ============ #}
    <div class="card">
        <div class="card-head">
            {{ icon('list', size=16) }}
            <h3>Assigned Tasks</h3>
        </div>
        <div class="card-body" style="padding:0;">
            <table class="tbl">
                <thead>
                    <tr>
                        <th>Task Name</th>
                        <th>Type</th>
                        <th class="center">Control</th>
                    </tr>
                </thead>
                <tbody>
                    {% for task_group_task in task_group_tasks %}
                        {% for task in tasks %}
                            {% if task_group_task == task.id %}
                                <tr>
                                    <td style="font-weight:500;">{{ task.name }}</td>
                                    <td style="color:var(--text-dim);">{{ task.hc_attackmode }}</td>
                                    <td class="center">
                                        <div style="display:flex; gap:4px; justify-content:center;">
                                            <a class="icon-btn" href="/task_groups/assigned_tasks/{{task_group.id}}/promote_task/{{task.id}}" role="button" title="Move Up">{{ icon('arrowUp', size=15) }}</a>
                                            <a class="icon-btn" href="/task_groups/assigned_tasks/{{task_group.id}}/demote_task/{{task.id}}" role="button" title="Move Down">{{ icon('arrowDown', size=15) }}</a>
                                            <a class="icon-btn act-del" href="/task_groups/assigned_tasks/{{task_group.id}}/remove_task/{{task.id}}" role="button" title="Delete">{{ icon('trash', size=15) }}</a>
                                        </div>
                                    </td>
                                </tr>
                            {% endif %}
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="3" style="text-align:center; padding:32px 16px; color:var(--text-dim);">
                                No tasks assigned yet. Add some from the library.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% endblock content %}
