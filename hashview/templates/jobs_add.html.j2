{% extends "layout.html.j2" %}
{% from "macros.html.j2" import icon, phos_field, status_badge, priority_pips, wizard_stepper %}
{% block title %}Create Job · Hashview{% endblock %}
{% block content %}
<script>
    function showDiv(){
        var Index = document.getElementById('customer_id');
        // support all other attack types
        if(Index.value == 'add_new')
        {
          document.getElementById('new_customer_div').style.display = 'inline';
        }
        else
        {
          document.getElementById('new_customer_div').style.display = 'none';
        }
    }
    function updatePriority(v){
        v = parseInt(v, 10);
        document.getElementById('priority_label').textContent = v + '/5';
        var html = '<span style="display:inline-flex;gap:3px;">';
        for (var i = 1; i <= 5; i++){
            var on = i <= v;
            var bg = on ? (v >= 4 ? 'var(--amber)' : 'var(--primary)') : 'var(--surface-3)';
            html += '<span style="width:5px;height:11px;border-radius:1px;background:' + bg + ';' + (on ? 'box-shadow:var(--glow-sm);' : '') + '"></span>';
        }
        html += '</span>';
        document.getElementById('priority_pips').innerHTML = html;
    }
</script>

<div class="page-head">
    <div>
        <h1 class="page-title">Create Job</h1>
        <div class="page-sub">// job setup · step 1 of 5</div>
    </div>
</div>

{{ wizard_stepper('setup') }}

<form method="POST" action="" enctype="multipart/form-data">
    {{ jobsForm.hidden_tag() }}

    <div class="card">
        <div class="card-head">
            <h3>Job Information</h3>
            <span class="field-hint" style="margin-top:0;">Provide the name of the job and the customer it is for.</span>
        </div>
        <div class="card-body">

            {{ phos_field(jobsForm.name) }}

            <div class="field">
                <label class="field-label" for="customer_id">Customer <span class="req">*</span></label>
                <select class="select" id="customer_id" name="customer_id" onchange="showDiv()" required>
                    <option value>--SELECT--</option>
                    {% for customer in customers %}
                        <option value='{{customer.id}}'>{{customer.name}}</option>
                    {% endfor %}
                    <option value='add_new'>New Customer</option>
                </select>
            </div>

            <div class="field" style="display:none" id="new_customer_div">
                <label class="field-label" for="name">Customer Name <span class="req">*</span></label>
                <input class="input" id="name" name="customer_name" type="text">
            </div>

            {% if settings.enabled_job_weights %}
            <div class="field">
                <label class="field-label">Job Priority <span style="color:var(--text-mute);font-weight:400;">· higher runs first</span></label>
                <div style="display:flex;align-items:center;gap:16px;">
                    <input type="range" class="hv-range" id="priority" name="priority" min="1" max="5" step="1"
                           value="{{ jobsForm.priority.data or 3 }}" style="flex:1;" oninput="updatePriority(this.value)">
                    <div style="display:flex;align-items:center;gap:9px;min-width:96px;">
                        <span id="priority_pips">{{ priority_pips((jobsForm.priority.data or 3)|int) }}</span>
                        <span class="mono" id="priority_label" style="color:var(--primary);font-size:14px;text-shadow:var(--glow-text);">{{ jobsForm.priority.data or 3 }}/5</span>
                    </div>
                </div>
            </div>
            {% endif %}

            <div class="field" style="margin-bottom:0;">
                <label style="display:flex;align-items:center;gap:12px;cursor:pointer;">
                    <span class="switch">{{ jobsForm.limit_recovered(id="limit_recovered") }}<span class="track"></span></span>
                    <span>
                        <span style="display:block;font-size:13px;color:var(--text);">Stop job after one hash has been recovered</span>
                        <span class="field-hint" style="margin-top:2px;">Ends the job as soon as any single hash is cracked</span>
                    </span>
                </label>
            </div>

        </div>
    </div>

    <div class="wizard-nav">
        <a class="btn" href="{{ url_for('jobs.jobs_list') }}" role="button">{{ icon('arrowLeft', size=15) }} Cancel</a>
        <span class="spacer"></span>
        {{ jobsForm.submit(class="btn btn-primary") }}
    </div>
</form>

{% endblock content %}
