{% extends "layout.html.j2" %}
{% from "macros.html.j2" import icon, phos_field %}
{% block title %}Create Task Group · Hashview{% endblock %}
{% block content %}

<div class="page-head">
    <div>
        <h1 class="page-title">Create Task Group</h1>
        <div class="page-sub">// enter the name of the task group</div>
    </div>
</div>

<form method="POST" action="" enctype="multipart/form-data">
    {{ task_group_form.hidden_tag() }}

    <div class="card">
        <div class="card-head">
            <h3>New Task Group</h3>
            <span class="field-hint" style="margin-top:0;">Enter the name of the task group.</span>
        </div>
        <div class="card-body">
            {{ phos_field(task_group_form.name) }}
        </div>
    </div>

    <div class="wizard-nav">
        <a class="btn" href="{{ url_for('task_groups.task_groups_list') }}" role="button">{{ icon('arrowLeft', size=15) }} Cancel</a>
        <span class="spacer"></span>
        {{ task_group_form.submit(class="btn btn-primary") }}
    </div>
</form>

{% endblock content %}
