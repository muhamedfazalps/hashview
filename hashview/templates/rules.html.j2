{% extends "layout.html.j2" %}
{% from "icons.html.j2" import icon %}
{% block title %}Rules · Hashview{% endblock %}
{% block content %}
{% macro rcount(n) -%}
{%- if n and n >= 1000000 -%}{{ (n / 1000000)|round(1) }}M{%- elif n and n >= 1000 -%}{{ (n / 1000)|round(1) }}K{%- else -%}{{ n or 0 }}{%- endif -%}
{%- endmacro %}
{% macro kv_label(t) -%}<div class="mono" style="font-size:9.5px; letter-spacing:1px; text-transform:uppercase; color:var(--text-mute); margin-bottom:6px;">{{ t }}</div>{%- endmacro %}

<div class="page-head">
    <div>
        <h1 class="page-title">Rules</h1>
        <div class="page-sub">// {{ rules|length }} rulesets applied as mutations over wordlists</div>
    </div>
    <button type="button" class="btn btn-primary" onclick="document.getElementById('upload-rule-modal').showModal()">{{ icon('upload', size=15) }} Upload rules</button>
</div>

<div class="card">
    {# ---- filter bar: magnifying glass beside the input, top-right of the card ---- #}
    <div class="card-head" style="justify-content:flex-end;">
        <span style="color:var(--text-mute); display:inline-flex;">{{ icon('search', size=16) }}</span>
        <input type="text" id="rule-filter" class="input" style="width:260px; flex:none;" placeholder="filter rules…" autocomplete="off" oninput="hvFilterRules(this.value)">
    </div>
    {% if rules %}
    <table class="tbl">
        <thead>
            <tr>
                <th>Name</th>
                <th>Rules</th>
                <th>Owner</th>
                <th>Last Updated</th>
                <th class="center">Control</th>
            </tr>
        </thead>
        <tbody id="rule-tbody">
            {% for rule in rules %}
            <tr data-name="{{ rule.name|lower }}">
                <td style="font-weight:500;">
                    <span style="display:inline-flex; align-items:center; gap:9px;">
                        <span style="color:var(--text-mute); display:inline-flex;">{{ icon('rule', size=16) }}</span>
                        {{ rule.name }}
                    </span>
                </td>
                <td class="mono num"><span style="color:{{ 'var(--primary)' if rule.size else 'var(--text-mute)' }};{% if rule.size %}text-shadow:var(--glow-text);{% endif %}">{{ "{:,}".format(rule.size|int) }}</span></td>
                <td class="mono" style="color:var(--text-dim);">{% for user in users %}{% if user.id == rule.owner_id %}{{ user.first_name }} {{ user.last_name }}{% endif %}{% endfor %}</td>
                <td class="mono" style="color:var(--text-mute);font-size:11.5px;">{{ rule.last_updated }}</td>
                <td class="center">
                    <div style="display:flex; gap:4px; justify-content:center;">
                        <a class="icon-btn" href="{{ url_for('rules.rules_download', rule_id=rule.id) }}" title="Download">{{ icon('download', size=15) }}</a>
                        <a class="icon-btn" href="{{ url_for('rules.rules_view', rule_id=rule.id) }}" title="View/Edit">{{ icon('edit', size=15) }}</a>
                        <button type="button" class="icon-btn" title="Info" onclick="document.getElementById('info-{{ rule.id }}').showModal()">{{ icon('info', size=15) }}</button>
                        <button type="button" class="icon-btn act-del" title="Delete" onclick="document.getElementById('del-{{ rule.id }}').showModal()">{{ icon('trash', size=15) }}</button>
                    </div>
                </td>
            </tr>
            {% endfor %}
            <tr id="rule-no-match" style="display:none;"><td colspan="5" style="text-align:center; padding:28px 16px; color:var(--text-mute);" class="mono">No rules match that filter.</td></tr>
        </tbody>
    </table>
    {% else %}
    <div class="card-body" style="text-align:center; padding:48px 24px;">
        <div class="mono" style="color:var(--text-dim); margin-bottom:14px;">No rules found.</div>
        <button type="button" class="btn btn-primary" onclick="document.getElementById('upload-rule-modal').showModal()">{{ icon('upload', size=15) }} Upload rules</button>
    </div>
    {% endif %}
</div>

{# ---- upload-rule modal (opened from the "Upload rules" button) ---- #}
<dialog class="hv-dialog" id="upload-rule-modal" style="max-width:560px; width:92vw;">
    <div class="hv-dialog-head">
        {{ icon('rule', size=16) }}
        <div style="line-height:1.2;">
            <h3 style="margin:0;">Upload Rule</h3>
            <div class="mono" style="font-size:10px; letter-spacing:0.5px; text-transform:uppercase; color:var(--text-mute); margin-top:3px;">hashcat-compatible .rule file</div>
        </div>
        <button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button>
    </div>
    <form method="POST" action="{{ url_for('rules.rules_add') }}" enctype="multipart/form-data">
        {{ rulesForm.hidden_tag() }}
        {{ rulesForm.name(id="rule-up-name", style="display:none;") }}
        <div class="hv-dialog-body">
            <div class="dropzone" id="rule-dropzone" onclick="document.getElementById('rule-up-file').click()"
                 ondragover="event.preventDefault(); this.classList.add('drag');"
                 ondragleave="this.classList.remove('drag');"
                 ondrop="hvRuleDrop(event)">
                {{ icon('upload', size=34) }}
                <div style="margin-top:12px; color:var(--text);">Drop a <span class="mono" style="color:var(--primary);">.rule</span> file here or <span style="color:var(--primary); text-decoration:underline;">browse</span></div>
                <div class="field-hint mono" id="rule-dropzone-name" style="margin-top:8px;">best64.rule, dive.rule, OneRuleToRuleThemAll.rule… one transform per line</div>
                {{ rulesForm.rules(id="rule-up-file", style="display:none;", onchange="hvRuleChosen(this)") }}
            </div>
            {% if rulesForm.rules.errors %}<div class="invalid-feedback">{% for e in rulesForm.rules.errors %}<span>{{ e }}</span>{% endfor %}</div>{% endif %}
        </div>
        <div class="hv-dialog-foot">
            <button type="button" class="btn" onclick="this.closest('dialog').close()">Cancel</button>
            <button type="submit" class="btn btn-primary">{{ icon('upload', size=15) }} Upload rule</button>
        </div>
    </form>
</dialog>
<script>
    function hvRuleChosen(input){
        var n = (input.files && input.files.length) ? input.files[0].name : '';
        var hint = document.getElementById('rule-dropzone-name');
        if (hint) hint.textContent = n ? ('Selected: ' + n) : 'best64.rule, dive.rule, OneRuleToRuleThemAll.rule… one transform per line';
        var nameEl = document.getElementById('rule-up-name');
        if (nameEl && n) nameEl.value = n;
    }
    function hvRuleDrop(e){
        e.preventDefault();
        var dz = document.getElementById('rule-dropzone');
        if (dz) dz.classList.remove('drag');
        var input = document.getElementById('rule-up-file');
        if (input && e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files.length){
            input.files = e.dataTransfer.files;
            hvRuleChosen(input);
        }
    }
</script>

{# ---- per-rule modals (native <dialog>, no framework) ---- #}
{% for rule in rules %}
<dialog class="hv-dialog" id="info-{{ rule.id }}" style="max-width:720px; width:95vw;">
    {% set used = rule_used_tasks.get(rule.id, []) if rule_used_tasks is defined else [] %}
    {% set hits = rule_hits.get(rule.id, 0) if rule_hits is defined else 0 %}
    {% set tcount = rule_task_count.get(rule.id, 0) if rule_task_count is defined else 0 %}
    {% set jcount = rule_job_count.get(rule.id, 0) if rule_job_count is defined else 0 %}
    {# size on disk is not tracked yet — placeholder until it's wired up #}
    {% set size_on_disk = '—' %}
    <div class="hv-dialog-head">
        {{ icon('info', size=16) }}
        <div style="line-height:1.2;">
            <h3 style="margin:0;">{{ rule.name }}</h3>
            <div class="mono" style="font-size:10px; letter-spacing:0.5px; color:var(--text-mute); margin-top:3px;">ruleset details</div>
        </div>
        <button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button>
    </div>
    <div class="hv-dialog-body" style="max-height:74vh; overflow-y:auto;">
        {# summary strip #}
        <div style="display:flex; align-items:center; gap:14px; margin-bottom:22px;">
            <span style="flex:none; width:46px; height:46px; border-radius:11px; display:inline-flex; align-items:center; justify-content:center; color:var(--primary); border:1px solid var(--primary-dim); background:rgba(var(--primary-rgb),0.08);">{{ icon('rule', size=20) }}</span>
            <div style="line-height:1.4;">
                <span class="mono" style="font-size:22px; color:var(--text);">{{ rcount(rule.size) }}<span style="font-size:12px; color:var(--text-mute);"> rules</span></span>
                <div class="mono" style="font-size:11px; color:var(--text-mute); margin-top:3px;">uploaded {{ rule.last_updated.strftime('%Y-%m-%d') if rule.last_updated else '—' }}</div>
            </div>
            <span style="margin-left:auto; text-align:right; line-height:1;">
                <span class="mono" style="font-size:22px; color:var(--primary); text-shadow:var(--glow-text);">{{ "{:,}".format(hits|int) }}</span>
                <span class="mono" style="display:block; font-size:9px; letter-spacing:1px; color:var(--text-mute); margin-top:3px;">HITS</span>
            </span>
        </div>

        {# detail grid (no note) #}
        <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 18px 24px;">
            <div>{{ kv_label('Owner') }}<div><span class="badge dim">{{ rule_owner.get(rule.id, '—') if rule_owner is defined else '—' }}</span></div></div>
            <div>{{ kv_label('Uploaded') }}<div class="mono" style="color:var(--text);">{{ rule.last_updated.strftime('%Y-%m-%d') if rule.last_updated else '—' }}</div></div>
            <div>{{ kv_label('Rules') }}<div class="mono" style="color:var(--text);">{{ "{:,}".format(rule.size|int) }}</div></div>
            <div>{{ kv_label('Historical hits') }}<div><span class="mono" style="color:{{ 'var(--primary)' if hits else 'var(--text-mute)' }};{% if hits %}text-shadow:var(--glow-text);{% endif %}">{{ "{:,}".format(hits|int) }}</span> <span style="color:var(--text-dim);">passwords recovered</span></div></div>
            <div>{{ kv_label('Used by') }}<div style="color:var(--text);">{{ tcount }} task{{ '' if tcount == 1 else 's' }} · {{ jcount }} job{{ '' if jcount == 1 else 's' }}</div></div>
        </div>

        {# used-by tasks #}
        <div style="margin-top:24px;">
            <div class="mono" style="display:flex; align-items:center; gap:8px; font-size:10px; letter-spacing:1px; text-transform:uppercase; color:var(--text-mute); margin-bottom:11px;">{{ icon('task', size=14) }} Used by {{ used|length }} task{{ '' if used|length == 1 else 's' }}</div>
            {% if used %}
            {% for u in used %}
            <div class="card" style="margin-bottom:8px; padding:11px 14px; display:flex; align-items:center; gap:10px;">
                <span style="color:var(--text-mute); display:inline-flex;">{{ icon('task', size=15) }}</span>
                <span style="font-weight:500; color:var(--text); min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="{{ u.name }}">{{ u.name }}</span>
                <span style="margin-left:auto; display:inline-flex; align-items:center; gap:10px; flex:none;">
                    {% if u.wordlist %}<span class="mono" style="color:var(--text-mute); font-size:11px;">{{ u.wordlist }}</span>{% endif %}
                    <span class="badge dim" style="font-size:8.5px;">{{ u.type }}</span>
                    <span class="mono" style="color:{{ 'var(--primary)' if u.hits else 'var(--text-mute)' }}; white-space:nowrap;">{{ "{:,}".format(u.hits|int) }} hits</span>
                </span>
            </div>
            {% endfor %}
            {% else %}
            <div class="mono" style="color:var(--text-mute);">Not used by any tasks yet.</div>
            {% endif %}
        </div>
    </div>
    <div class="hv-dialog-foot">
        <span class="mono" style="margin-right:auto; font-size:11.5px; color:var(--text-mute);">{{ "{:,}".format(rule.size|int) }} rules · {{ size_on_disk }}</span>
        <button class="btn" onclick="this.closest('dialog').close()">Close</button>
    </div>
</dialog>

<dialog class="hv-dialog" id="del-{{ rule.id }}">
    <div class="hv-dialog-head"><h3>Delete {{ rule.name }}?</h3><button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button></div>
    <div class="hv-dialog-body">This will permanently delete the rules file. Are you sure you want to continue?</div>
    <div class="hv-dialog-foot">
        <button class="btn" onclick="this.closest('dialog').close()">Back</button>
        <form action="{{ url_for('rules.rules_delete', rule_id=rule.id) }}" method="POST" style="display:inline;">
            <button class="btn btn-danger" type="submit">Delete</button>
        </form>
    </div>
</dialog>
{% endfor %}

<script>
function hvFilterRules(q){
    q = (q || '').trim().toLowerCase();
    var shown = 0;
    document.querySelectorAll('#rule-tbody tr[data-name]').forEach(function(tr){
        var hit = !q || (tr.getAttribute('data-name') || '').indexOf(q) !== -1;
        tr.style.display = hit ? '' : 'none';
        if (hit) shown++;
    });
    var none = document.getElementById('rule-no-match');
    if (none) none.style.display = shown === 0 ? '' : 'none';
}
</script>

{% endblock content %}
