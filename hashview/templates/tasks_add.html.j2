{% extends "layout.html.j2" %}
{% from "macros.html.j2" import icon, phos_field %}
{% block title %}Add Task · Hashview{% endblock %}
{% block content %}
<script>
    function showDiv(){
        var Index = document.getElementById('hc_attackmode');
        // support all other attack types
        if(Index.value == '0')
        {
            document.getElementById('dictionary_div').style.display = 'block';
            document.getElementById('combinator_div').style.display = 'none';
            document.getElementById('rules_div').style.display = 'block';
            document.getElementById('maskmode_div').style.display = 'none';
            document.getElementById('loopback_div').style.display = 'block';
        }
        else if (Index.value == '1')
        {
            document.getElementById('dictionary_div').style.display = 'block';
            document.getElementById('combinator_div').style.display = 'block';
            document.getElementById('rules_div').style.display = 'none';
            document.getElementById('maskmode_div').style.display = 'none';
            document.getElementById('loopback_div').style.display = 'none';
        }
        else if (Index.value == '3')
        {
            document.getElementById('dictionary_div').style.display = 'none';
            document.getElementById('combinator_div').style.display = 'none';
            document.getElementById('rules_div').style.display = 'none';
            document.getElementById('maskmode_div').style.display = 'block';
            document.getElementById('loopback_div').style.display = 'none';
        }
        else if (Index.value == '6' || Index.value == '7' )
        {
            document.getElementById('dictionary_div').style.display = 'block';
            document.getElementById('combinator_div').style.display = 'none';
            document.getElementById('rules_div').style.display = 'none';
            document.getElementById('maskmode_div').style.display = 'block';
            document.getElementById('loopback_div').style.display = 'none';
        }
        else
        {
            document.getElementById('dictionary_div').style.display = 'none';
            document.getElementById('combinator_div').style.display = 'none';
            document.getElementById('rules_div').style.display = 'none';
            document.getElementById('maskmode_div').style.display = 'none';
            document.getElementById('loopback_div').style.display = 'none';
        }
    }
</script>

<div class="page-head">
    <div>
        <h1 class="page-title">Add Task</h1>
        <div class="page-sub">// select from the following options to create a new task to be run</div>
    </div>
</div>

<form method="POST" action="" enctype="multipart/form-data">
    {{ tasksForm.hidden_tag() }}

    <div class="card">
        <div class="card-body">

            {{ phos_field(tasksForm.name) }}

            <div class="field">
                <label class="field-label" for="hc_attackmode">{{ tasksForm.hc_attackmode.label.text }}</label>
                {% if tasksForm.hc_attackmode.errors %}
                    {{ tasksForm.hc_attackmode(class="select is-invalid", onchange="showDiv()") }}
                    <div class="invalid-feedback">
                        {% for error in tasksForm.hc_attackmode.errors %}
                            <span>{{ error }}</span>
                        {% endfor %}
                    </div>
                {% else %}
                    {{ tasksForm.hc_attackmode(class="select", onchange="showDiv()") }}
                {% endif %}
            </div>

            <div class="field" style="display:none" id="dictionary_div">
                <label class="field-label" for="wl_id">{{ tasksForm.wl_id.label.text }}</label>
                {% if tasksForm.wl_id.errors %}
                    {{ tasksForm.wl_id(class="select is-invalid") }}
                    <div class="invalid-feedback">
                        {% for error in tasksForm.wl_id.errors %}
                            <span>{{ error }}</span>
                        {% endfor %}
                    </div>
                {% else %}
                    {{ tasksForm.wl_id(class="select") }}
                {% endif %}
            </div>

            <div class="field" style="display:none" id="rules_div">
                <label class="field-label" for="rule_id">{{ tasksForm.rule_id.label.text }}</label>
                {% if tasksForm.rule_id.errors %}
                    {{ tasksForm.rule_id(class="select is-invalid") }}
                    <div class="invalid-feedback">
                        {% for error in tasksForm.rule_id.errors %}
                            <span>{{ error }}</span>
                        {% endfor %}
                    </div>
                {% else %}
                    {{ tasksForm.rule_id(class="select") }}
                {% endif %}
            </div>

            <div class="field" style="display:none" id="loopback_div">
                <label style="display:flex;align-items:center;gap:12px;cursor:pointer;">
                    <span class="switch">{{ tasksForm.loopback(id="loopback") }}<span class="track"></span></span>
                    <span>
                        <span style="display:block;font-size:13px;color:var(--text);">Enable loopback</span>
                        <span class="field-hint" style="margin-top:2px;">After each pass, newly cracked passwords are fed back through the wordlist + rules and re-run until no new hashes are found. Can recover more passwords (e.g. Password1 &rarr; Password10) but increases runtime. Requires a rule to be selected.</span>
                    </span>
                </label>
            </div>

            <div class="field" style="display:none" id="maskmode_div">
                <label class="field-label" for="mask">{{ tasksForm.mask.label.text }}</label>
                {% if tasksForm.mask.errors %}
                    {{ tasksForm.mask(class="input is-invalid") }}
                    <div class="invalid-feedback">
                        {% for error in tasksForm.mask.errors %}
                            <span>{{ error }}</span>
                        {% endfor %}
                    </div>
                {% else %}
                    {{ tasksForm.mask(class="input") }}
                {% endif %}
            </div>

            <div class="field" style="display:none;margin-bottom:0;" id="combinator_div">
                <div class="field">
                    <label class="field-label" for="wl_id_2">{{ tasksForm.wl_id_2.label.text }}</label>
                    {% if tasksForm.wl_id_2.errors %}
                        {{ tasksForm.wl_id_2(class="select is-invalid") }}
                        <div class="invalid-feedback">
                            {% for error in tasksForm.wl_id_2.errors %}
                                <span>{{ error }}</span>
                            {% endfor %}
                        </div>
                    {% else %}
                        {{ tasksForm.wl_id_2(class="select") }}
                    {% endif %}
                </div>
                <div class="field">
                    <label class="field-label" for="j_rule">{{ tasksForm.j_rule.label.text }}</label>
                    {% if tasksForm.j_rule.errors %}
                        {{ tasksForm.j_rule(class="input is-invalid") }}
                        <div class="invalid-feedback">
                            {% for error in tasksForm.j_rule.errors %}
                                <span>{{ error }}</span>
                            {% endfor %}
                        </div>
                    {% else %}
                        {{ tasksForm.j_rule(class="input") }}
                    {% endif %}
                </div>
                <div class="field" style="margin-bottom:0;">
                    <label class="field-label" for="k_rule">{{ tasksForm.k_rule.label.text }}</label>
                    {% if tasksForm.k_rule.errors %}
                        {{ tasksForm.k_rule(class="input is-invalid") }}
                        <div class="invalid-feedback">
                            {% for error in tasksForm.k_rule.errors %}
                                <span>{{ error }}</span>
                            {% endfor %}
                        </div>
                    {% else %}
                        {{ tasksForm.k_rule(class="input") }}
                    {% endif %}
                </div>
            </div>

        </div>
    </div>

    <div class="wizard-nav">
        <a class="btn" href="{{ url_for('tasks.tasks_list') }}" role="button">{{ icon('arrowLeft', size=15) }} Cancel</a>
        <span class="spacer"></span>
        {{ tasksForm.submit(class="btn btn-primary") }}
    </div>
</form>

{% endblock content %}
