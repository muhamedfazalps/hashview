{% extends "layout.html.j2" %}
{% from "icons.html.j2" import icon %}
{% from "macros.html.j2" import status_badge %}
{% block title %}Agents · Hashview{% endblock %}
{% block content %}

<div class="page-head">
    <div>
        <h1 class="page-title">Agents</h1>
        <div class="page-sub">// Remote workers that process distributed hashcat jobs</div>
    </div>
    <a class="btn btn-primary" href="{{ url_for('agents.agents_download') }}" role="button">{{ icon('download', size=15) }} Download Agent</a>
</div>

<div class="card">
    {% if agents %}
    <table class="tbl">
        <thead>
            <tr>
                <th>Agent Name</th>
                <th>Status</th>
                <th>IP</th>
                <th>Speed</th>
                <th>Last Heartbeat</th>
                <th class="center" style="width:160px;">Control</th>
            </tr>
        </thead>
        <tbody>
            {% for agent in agents %}
            <tr>
                <td style="font-weight:500;">{{ agent.name }}</td>
                <td>
                    <span style="display:inline-flex; align-items:center; gap:8px;">
                        {% if agent.status == 'Pending' %}
                            <span class="dot-led idle"></span>
                        {% elif agent.status == 'Working' or agent.status == 'Syncing' %}
                            <span class="dot-led run"></span>
                        {% elif agent.status == 'Idle' or agent.status == 'Authorized' %}
                            <span class="dot-led on"></span>
                        {% else %}
                            <span class="dot-led off"></span>
                        {% endif %}
                        {{ status_badge(agent.status) }}
                    </span>
                </td>
                <td class="mono" style="color:var(--text-dim);">{{ agent.src_ip }}</td>
                <td class="num">{{ agent.benchmark }}</td>
                <td class="mono" style="color:var(--text-dim);">{{ agent.last_checkin }}</td>
                <td class="center">
                    <div style="display:flex; gap:4px; justify-content:center;">
                        {% if agent.status == 'Pending' %}
                            <a class="icon-btn act-go" href="{{ url_for('agents.agents_authorize', agent_id=agent.id) }}" role="button" title="Authorize">{{ icon('check', size=15) }}</a>
                        {% else %}
                            <a class="icon-btn act-stop" href="{{ url_for('agents.agents_deauthorize', agent_id=agent.id) }}" role="button" title="Deauthorize">{{ icon('ban', size=15) }}</a>
                        {% endif %}
                        <a class="icon-btn" href="{{ url_for('agents.agents_edit', agent_id=agent.id) }}" role="button" title="Edit">{{ icon('edit', size=15) }}</a>
                        <button type="button" class="icon-btn act-del" title="Delete" onclick="document.getElementById('del-{{ agent.id }}').showModal()">{{ icon('trash', size=15) }}</button>
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <div class="card-body" style="text-align:center; padding:48px 24px;">
        <div class="mono" style="color:var(--text-dim); margin-bottom:14px;">No agents registered.</div>
        <a class="btn btn-primary" href="{{ url_for('agents.agents_download') }}" role="button">{{ icon('download', size=15) }} Download Agent</a>
    </div>
    {% endif %}
</div>

{# ---- per-agent delete modals (native <dialog>, no framework) ---- #}
{% for agent in agents %}
<dialog class="hv-dialog" id="del-{{ agent.id }}">
    <div class="hv-dialog-head"><h3>Delete {{ agent.name }}?</h3><button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button></div>
    <div class="hv-dialog-body">This will permanently delete the agent. Are you sure you want to continue?</div>
    <div class="hv-dialog-foot">
        <button class="btn" onclick="this.closest('dialog').close()">Back</button>
        <form action="{{ url_for('agents.agents_delete', agent_id=agent.id) }}" method="POST" style="display:inline;">
            <button class="btn btn-danger" type="submit">Delete</button>
        </form>
    </div>
</dialog>
{% endfor %}

{% endblock content %}
