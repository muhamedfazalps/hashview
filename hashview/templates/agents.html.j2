{% extends "layout.html.j2" %}
{% block header %}
<br>
<br>
<br>
<br>
<br>
{% endblock header %}
{% block content %}
    <article class="media content-section">
        <div class="media-body">
            <div class="card">
                <h4 class="card-header">
                    Agents 
                    <i class="fa fa-question-circle fa-sm" data-toggle="tooltip" title="Agents are remote workers that process distributed hashcat jobs." style="margin-left:5px;"></i>
                    <a class="fa fa-download btn btn-sm btn-success pull-right" href="/agents/download" role="button" title=Download></a>
                </h4>
                <div class="card-body ">  
                    <table class="table table-sm">
                        <thead>
                        <tr>
                            <th scope="col">Agent Name</th>
                            <th scope="col">Status</th>
                            <th scope="col">IP</th>
                            <th scope="col">Speed</th>
                            <th scope="col">Last Heartbeat</th>
                            <th style="width:140px" scope="col">Control</th>                  
                        </tr>
                        </thead>
                        <tbody>
                            {% for agent in agents %}
                                <tr>
                                    <td style=vertical-align:middle;>{{ agent.name }}</td>
                                    <td style=vertical-align:middle;>{{ agent.status }}</td>
                                    <td style=vertical-align:middle;>{{ agent.src_ip }}</td>
                                    <td style=vertical-align:middle;>{{ agent.benchmark }}</td>
                                    <td style=vertical-align:middle;>{{ agent.last_checkin}}</td>
                                    <td style=vertical-align:middle;>
                                        {% if agent.status == 'Pending' %}
                                            <a class="fa fa-check btn btn-success" href="/agents/{{agent.id}}/authorize" role="button" title=Authorize></a>
                                        {% else %}
                                            <a class="fa fa-close btn btn-secondary" href="/agents/{{agent.id}}/deauthorize" role="button" title=Deauthorize></a>
                                        {% endif %}
                                            <a class="fa fa-edit btn btn-warning" href="/agents/edit/{{agent.id}}" role="button" title=Edit></a>
                                        <button type="button" class="fa fa-trash fa-1x btn btn-danger" data-toggle="modal" data-target="#deleteModal{{agent.id}}" title=Delete></button>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>    
        </div>
    </article>
    {% for agent in agents %}
    <!-- DeleteModal -->
    <div class="modal fade" id="deleteModal{{agent.id}}" tabindex="-1" aria-labelledby="deleteModal{{agent.id}}Label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
            <h5 class="modal-title" id="deleteModal{{agent.id}}Label">Delete: {{agent.name}} ?</h5>
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
            </div>
            <div class="modal-body">
            This will permanantly delete the job. Are you sure you want to continue?
            </div>
            <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-dismiss="modal">Back</button>
            <form action="{{ url_for('agents.agents_delete', agent_id=agent.id) }}" method="POST">
                <input class="btn btn-danger" type="submit" value="Delete">
            </form>
            </div>
        </div>
        </div>
    </div>
{% endfor %}
{% endblock content %}
