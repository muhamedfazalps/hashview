<!DOCTYPE html>
<html lang="en" data-glow="subtle" data-scanlines="on" data-density="comfortable">
<head>
    <meta charset="UTF-8">
    <title>Hashview v{{ get_application_version() }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link rel="icon" type="image/svg+xml" href="{{ url_for('static', filename='favicon.svg') }}">

    <link type="text/css" rel="stylesheet" href="{{ url_for('static', filename='main.css') }}">

    {# --- Phosphor Console design system (self-hosted) --- #}
    <link rel="stylesheet" href="{{ url_for('static', filename='fonts/plex.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/phosphor.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/phosphor-app.css') }}">
</head>
<body>
    <div class="scanlines"></div>

    <div class="auth-body">
        <div class="auth-wrap">
            <div class="brand-lg"><span class="brand-mark">#</span> hash<b>view</b></div>
            <div class="card">
                <div class="card-body">
                    <div class="auth-title">{% block setup_title %}Setup{% endblock %}</div>
                    {% block content %}{% endblock %}
                </div>
            </div>
        </div>
    </div>

</body>
</html>
