{% extends "layout.html.j2" %}
{% from "macros.html.j2" import icon, phos_field, status_badge, priority_pips, wizard_stepper %}
{% block content %}

<div class="page-head">
    <div>
        <h1 class="page-title">Create Job</h1>
        <div class="page-sub">// website keywords</div>
    </div>
</div>
{{ wizard_stepper('website', alert_hashes=(alert_hashes if alert_hashes is defined else false), website=true) }}

<form method="POST" action="">
    {{ form.hidden_tag() }}

    <div class="card">
        <div class="card-head">{{ icon('search', size=15) }}<h3>Website Keywords</h3></div>
        <div class="card-body">
            <div class="field-hint" style="margin-bottom:16px;">
                One or more of this job's tasks use the <span class="mono">(DYNAMIC) Website Keywords</span> wordlist.
                Enter a single URL to crawl — every task in this job that uses that wordlist will be built from the
                words scraped from this site (using the crawler settings configured under Settings).
            </div>
            {{ phos_field(form.crawl_url, placeholder='https://example.com') }}
        </div>
    </div>

    <div class="wizard-nav">
        <a class="btn" href="{{ url_for('jobs.jobs_list_tasks', job_id=job.id) }}">{{ icon('arrowLeft', size=15) }} Back</a>
        <span class="spacer"></span>
        {{ form.submit(class="btn btn-primary") }}
    </div>
</form>

{% endblock content %}
