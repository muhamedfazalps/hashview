{% extends "layout.html.j2" %}
{% from "macros.html.j2" import icon, phos_field %}
{% block title %}Profile · Hashview{% endblock %}
{% block content %}

<div class="page-head">
    <div>
        <h1 class="page-title">Profile</h1>
        <div class="page-sub">// manage your account details and notification credentials</div>
    </div>
</div>

<form method="POST" action="" enctype="multipart/form-data">
    {{ form.hidden_tag() }}

    <div class="card">
        <div class="card-body">

            {{ phos_field(form.first_name) }}
            {{ phos_field(form.last_name) }}
            {{ phos_field(form.email) }}

            <div class="field">
                <label class="field-label" for="formControlReadonly">User API Key</label>
                <div style="display:flex; gap:8px; align-items:stretch;">
                    {% if current_user.api_key %}
                        <input class="input mono" id="formControlReadonly" type="text" value="{{ current_user.api_key }}" aria-label="User API Key" readonly style="flex:1;"/>
                    {% else %}
                        <input class="input mono" id="formControlReadonly" type="text" value="No key set" aria-label="User API Key" readonly style="flex:1;"/>
                    {% endif %}
                    <a class="btn" href="{{ url_for('users.generate_api_key') }}" role="button" title="Generate new API key">{{ icon('refresh', size=15) }} Generate</a>
                </div>
            </div>

            {% if current_user.pushover_user_key %}
                {{ phos_field(form.pushover_user_key, placeholder='Pushover Key Set') }}
            {% else %}
                {{ phos_field(form.pushover_user_key) }}
            {% endif %}

            {% if current_user.pushover_app_id %}
                {{ phos_field(form.pushover_app_id, placeholder='Pushover Id Set') }}
            {% else %}
                {{ phos_field(form.pushover_app_id) }}
            {% endif %}

        </div>
    </div>

    <div class="wizard-nav">
        <a class="btn" href="{{ url_for('main.home') }}" role="button">{{ icon('arrowLeft', size=15) }} Cancel</a>
        <span class="spacer"></span>
        {% if not current_user.pushover_app_id or not current_user.pushover_user_key %}
            <a class="btn disabled" href="#" aria-disabled="true">{{ icon('bell', size=15) }} Test Pushover</a>
        {% else %}
            <a class="btn" href="{{ url_for('users.send_test_pushover') }}">{{ icon('bell', size=15) }} Test Pushover</a>
        {% endif %}
        <a class="btn" href="{{ url_for('users.send_test_email') }}">{{ icon('mail', size=15) }} Test Email</a>
        {{ form.submit(class="btn btn-primary") }}
    </div>
</form>

{% endblock content %}
