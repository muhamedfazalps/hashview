{% extends "layout.html.j2" %}
{% from "icons.html.j2" import icon %}
{% from "macros.html.j2" import status_badge, priority_pips %}
{% block title %}Jobs · Hashview{% endblock %}
{% block content %}
{% macro kv_label(t) -%}<div class="mono" style="font-size:9.5px; letter-spacing:1px; text-transform:uppercase; color:var(--text-mute); margin-bottom:6px;">{{ t }}</div>{%- endmacro %}

<div class="page-head">
    <div>
        <h1 class="page-title">Jobs</h1>
        <div class="page-sub">// {{ pagination.total }} jobs total · page {{ pagination.page }}/{{ pagination.pages or 1 }}</div>
    </div>
    <div style="display:flex; gap:10px;">
        {% if show_only_mine == 'true' %}
            <a class="btn active" href="{{ url_for('jobs.jobs_list', show_only_mine='false', page=1) }}">{{ icon('users', size=15) }} All jobs</a>
        {% else %}
            <a class="btn" href="{{ url_for('jobs.jobs_list', show_only_mine='true', page=1) }}">{{ icon('users', size=15) }} Only mine</a>
        {% endif %}
        <a class="btn btn-primary" href="{{ url_for('jobs.jobs_add') }}">{{ icon('plus', size=15) }} New Job</a>
    </div>
</div>

<div class="card">
    <div class="card-head" style="justify-content:flex-end;">
        <span style="color:var(--text-mute); display:inline-flex;">{{ icon('search', size=16) }}</span>
        <input type="text" id="job-filter" class="input" style="width:260px; flex:none;" placeholder="filter jobs…" autocomplete="off" oninput="hvFilterJobs(this.value)">
    </div>
    {% if jobs %}
    <table class="tbl">
        <thead>
            <tr>
                <th>Job</th><th>Customer</th><th>Hashfile</th>
                <th class="center">Status</th><th class="center">Cracked</th><th class="center">Priority</th>
                <th>Owner</th><th>Created</th><th class="center">Control</th>
            </tr>
        </thead>
        <tbody id="job-tbody">
            {% for job in jobs %}
            {% set ns = namespace(cust='', hf='', owner='') %}
            {% for c in customers %}{% if c.id == job.customer_id %}{% set ns.cust = c.name %}{% endif %}{% endfor %}
            {% for h in hashfiles %}{% if h.id == job.hashfile_id %}{% set ns.hf = h.name %}{% endif %}{% endfor %}
            {% for u in users %}{% if u.id == job.owner_id %}{% set ns.owner = u.first_name ~ ' ' ~ u.last_name %}{% endif %}{% endfor %}
            <tr data-name="{{ job.name|lower }} {{ ns.cust|lower }}">
                <td style="font-weight:500;"><div title="{{ job.name }}" style="max-width:240px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{{ job.name }}</div></td>
                <td style="color:var(--text-dim);"><div title="{{ ns.cust }}" style="max-width:160px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{{ ns.cust }}</div></td>
                <td class="mono" style="color:var(--text-dim);"><div title="{{ ns.hf }}" style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{{ ns.hf }}</div></td>
                <td class="center">{{ status_badge(job.status) }}</td>
                <td class="center">
                    {% set cr = job_cracked.get(job.id) if job_cracked is defined else none %}
                    {% if cr and cr.total %}
                    <div class="mono num" style="font-size:12.5px;white-space:nowrap;">
                        <span style="color:{{ 'var(--primary)' if cr.cracked else 'var(--text-dim)' }};{% if cr.cracked %}text-shadow:var(--glow-text);{% endif %}">{{ "{:,}".format(cr.cracked) }}</span><span style="color:var(--text-mute);">/{{ "{:,}".format(cr.total) }}</span>
                    </div>
                    <div style="height:3px;width:84px;margin:6px auto 0;border-radius:2px;background:var(--surface-3);overflow:hidden;">
                        <div style="height:100%;width:{{ cr.pct }}%;background:linear-gradient(90deg,var(--primary-deep),var(--primary));box-shadow:var(--glow-sm);"></div>
                    </div>
                    {% else %}
                    <span style="color:var(--text-mute);">—</span>
                    {% endif %}
                </td>
                <td class="center">{{ priority_pips(job.priority) }}</td>
                <td class="mono" style="color:var(--text-dim);"><div title="{{ ns.owner }}" style="max-width:150px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{{ ns.owner }}</div></td>
                <td class="mono" style="color:var(--text-mute);font-size:11.5px;">{{ job.created_at.strftime('%b %d %H:%M') if job.created_at else '—' }}</td>
                <td class="center">
                    <button type="button" class="icon-btn" id="jobmenubtn-{{ job.id }}" popovertarget="jobmenu-{{ job.id }}" title="Actions" aria-label="Actions">{{ icon('dots', size=16) }}</button>
                    <div class="job-menu" popover="auto" id="jobmenu-{{ job.id }}" data-anchor="jobmenubtn-{{ job.id }}">
                        {% if job.status == 'Ready' %}
                            <a class="mi go" href="{{ url_for('jobs.jobs_start', job_id=job.id) }}">{{ icon('play', size=15) }} Start</a>
                        {% elif job.status == 'Queued' or job.status == 'Running' %}
                            <a class="mi stop" href="{{ url_for('jobs.jobs_stop', job_id=job.id) }}">{{ icon('stop', size=15) }} Stop</a>
                        {% elif job.status == 'Completed' %}
                            <span class="mi disabled" style="color:var(--green);">{{ icon('check', size=15) }} Completed</span>
                        {% elif job.status == 'Canceled' %}
                            <a class="mi" href="{{ url_for('jobs.jobs_start', job_id=job.id) }}">{{ icon('refresh', size=15) }} Restart</a>
                        {% endif %}
                        {% if job.status != 'Incomplete' %}
                            <a class="mi" href="{{ url_for('analytics.get_analytics', customer_id=job.customer_id, hashfile_id=job.hashfile_id) }}">{{ icon('chart', size=15) }} Analytics</a>
                            <button type="button" class="mi" onclick="this.closest('[popover]').hidePopover(); document.getElementById('info-{{ job.id }}').showModal();">{{ icon('info', size=15) }} Info</button>
                        {% endif %}
                        {% if job.status == 'Running' or job.status == 'Queued' %}
                            <span class="mi disabled" title="Locked while active">{{ icon('edit', size=15) }} Edit</span>
                        {% else %}
                            <a class="mi" href="{{ url_for('jobs.jobs_assigned_hashfile', job_id=job.id) }}">{{ icon('edit', size=15) }} Edit</a>
                        {% endif %}
                        <div class="sep"></div>
                        <button type="button" class="mi danger" onclick="this.closest('[popover]').hidePopover(); document.getElementById('del-{{ job.id }}').showModal();">{{ icon('trash', size=15) }} Delete</button>
                    </div>
                </td>
            </tr>
            {% endfor %}
            <tr id="job-no-match" style="display:none;"><td colspan="9" style="text-align:center; padding:28px 16px; color:var(--text-mute);" class="mono">No jobs match that filter.</td></tr>
        </tbody>
    </table>
    {% else %}
    <div class="card-body" style="text-align:center; padding:48px 24px;">
        <div class="mono" style="color:var(--text-dim); margin-bottom:14px;">No jobs found.</div>
        <a class="btn btn-primary" href="{{ url_for('jobs.jobs_add') }}">{{ icon('plus', size=15) }} Create a New Job</a>
    </div>
    {% endif %}
</div>

{% if pagination.pages and pagination.pages > 1 %}
<div class="pager">
    {% if pagination.has_prev %}
        <a class="pager-btn" href="{{ url_for('jobs.jobs_list', page=pagination.prev_num, show_only_mine=show_only_mine) }}">‹ Prev</a>
    {% else %}
        <span class="pager-btn disabled">‹ Prev</span>
    {% endif %}
    {% for p in pagination.iter_pages(left_edge=2, right_edge=2, left_current=2, right_current=2) %}
        {% if p %}
            {% if p == pagination.page %}
                <span class="pager-btn active">{{ p }}</span>
            {% else %}
                <a class="pager-btn" href="{{ url_for('jobs.jobs_list', page=p, show_only_mine=show_only_mine) }}">{{ p }}</a>
            {% endif %}
        {% else %}
            <span class="pager-btn disabled">…</span>
        {% endif %}
    {% endfor %}
    {% if pagination.has_next %}
        <a class="pager-btn" href="{{ url_for('jobs.jobs_list', page=pagination.next_num, show_only_mine=show_only_mine) }}">Next ›</a>
    {% else %}
        <span class="pager-btn disabled">Next ›</span>
    {% endif %}
</div>
{% endif %}

<style>
.job-menu {
    position: fixed; inset: auto; margin: 0;
    min-width: 170px; padding: 5px;
    background: var(--surface-2);
    border: 1px solid var(--border-soft);
    border-radius: 9px;
    box-shadow: 0 10px 28px rgba(0,0,0,.5);
}
.job-menu .mi {
    display: flex; align-items: center; gap: 9px;
    width: 100%; box-sizing: border-box;
    padding: 7px 10px; margin: 0;
    font-family: var(--mono); font-size: 12px; letter-spacing: .3px;
    color: var(--text-dim);
    background: none; border: 0; border-radius: 6px;
    text-align: left; text-decoration: none; cursor: pointer;
    white-space: nowrap;
}
.job-menu .mi:hover { background: var(--surface-3); color: var(--text); }
.job-menu .mi .ico { width: 15px; height: 15px; flex: none; }
.job-menu .mi.go:hover { color: var(--green); }
.job-menu .mi.stop:hover { color: var(--amber); }
.job-menu .mi.danger { color: var(--red); }
.job-menu .mi.danger:hover { background: var(--surface-3); color: var(--red); }
.job-menu .mi.disabled { opacity: .4; cursor: default; }
.job-menu .mi.disabled:hover { background: none; color: inherit; }
.job-menu .sep { height: 1px; background: var(--border-soft); margin: 4px 2px; }
</style>
<script>
// Position each job actions popover next to its trigger button (top layer escapes
// the card's overflow:hidden). Drops below the button, flips above near the viewport
// bottom, and right-aligns to the button edge.
(function(){
    function place(menu){
        var btn = document.getElementById(menu.getAttribute('data-anchor'));
        if(!btn) return;
        var r = btn.getBoundingClientRect();
        var mw = menu.offsetWidth, mh = menu.offsetHeight;
        var left = r.right - mw;
        var maxLeft = window.innerWidth - mw - 8;
        if(left > maxLeft) left = maxLeft;
        if(left < 8) left = 8;
        var top = r.bottom + 4;
        if(top + mh > window.innerHeight - 8) top = r.top - mh - 4;
        if(top < 8) top = 8;
        menu.style.left = left + 'px';
        menu.style.top = top + 'px';
    }
    document.addEventListener('toggle', function(e){
        var t = e.target;
        if(t && t.classList && t.classList.contains('job-menu') && e.newState === 'open'){
            place(t);
        }
    }, true);
})();
function hvFilterJobs(q){
    q = (q || '').trim().toLowerCase();
    var shown = 0;
    document.querySelectorAll('#job-tbody tr[data-name]').forEach(function(tr){
        var hit = !q || (tr.getAttribute('data-name') || '').indexOf(q) !== -1;
        tr.style.display = hit ? '' : 'none';
        if (hit) shown++;
    });
    var none = document.getElementById('job-no-match');
    if (none) none.style.display = shown === 0 ? '' : 'none';
}
</script>

{# ---- per-job modals (native <dialog>, no framework) ---- #}
{% for job in jobs %}
<dialog class="hv-dialog" id="info-{{ job.id }}" style="max-width:680px; width:94vw;">
    {% set cr = job_cracked.get(job.id) if job_cracked is defined else none %}
    <div class="hv-dialog-head">
        {{ icon('info', size=16) }}
        <div style="line-height:1.2;">
            <h3 style="margin:0;">{{ job.name }}</h3>
            <div class="mono" style="font-size:10px; letter-spacing:0.5px; color:var(--text-mute); margin-top:3px;">job #{{ job.id }} · {% for c in customers %}{% if c.id == job.customer_id %}{{ c.name }}{% endif %}{% endfor %}</div>
        </div>
        <button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button>
    </div>
    <div class="hv-dialog-body" style="max-height:72vh; overflow-y:auto;">
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:8px;">
            {{ status_badge(job.status) }}
            <span class="mono" style="font-size:12.5px;">{% if cr %}<span style="color:var(--text);">{{ "{:,}".format(cr.cracked) }}</span><span style="color:var(--text-mute);"> / {{ "{:,}".format(cr.total) }} hashes recovered</span>{% endif %}</span>
            <span style="margin-left:auto; display:inline-block; text-align:center; line-height:1;">
                <span class="mono" style="font-size:24px; color:var(--primary); text-shadow:var(--glow-text);">{{ cr.pct if cr else 0 }}<span style="font-size:12px;">%</span></span>
                <span class="mono" style="display:block; font-size:9px; letter-spacing:1px; color:var(--text-mute); margin-top:2px;">CRACKED</span>
            </span>
        </div>
        <div style="height:4px; border-radius:2px; background:var(--surface-3); overflow:hidden; margin-bottom:20px;">
            <div style="height:100%; width:{{ cr.pct if cr else 0 }}%; background:linear-gradient(90deg,var(--primary-deep),var(--primary)); box-shadow:var(--glow-sm);"></div>
        </div>

        <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 18px 24px;">
            <div>{{ kv_label('Customer') }}<div style="color:var(--text);">{% for c in customers %}{% if c.id == job.customer_id %}{{ c.name }}{% endif %}{% endfor %}</div></div>
            <div>{{ kv_label('Owner') }}<div style="color:var(--text); display:inline-flex; align-items:center; gap:7px;">{{ icon('users', size=14) }}{% for u in users %}{% if u.id == job.owner_id %}{{ u.first_name }} {{ u.last_name }}{% endif %}{% endfor %}</div></div>
            <div>{{ kv_label('Hashfile') }}<div class="mono" style="color:var(--text);">{% for h in hashfiles %}{% if h.id == job.hashfile_id %}{{ h.name }}{% endif %}{% endfor %}{% if not job.hashfile_id %}<span style="color:var(--text-mute);">—</span>{% endif %}</div></div>
            <div>{{ kv_label('Hash type') }}<div>{% if job_hash_type is defined and job_hash_type.get(job.id) %}<span class="badge cyan">{{ job_hash_type[job.id] }}</span>{% else %}<span style="color:var(--text-mute);">—</span>{% endif %}</div></div>
            <div>{{ kv_label('Priority') }}<div style="display:inline-flex; align-items:center; gap:9px;">{{ priority_pips(job.priority) }}<span class="mono" style="color:var(--text-dim);">{{ job.priority }}/5</span></div></div>
            <div>{{ kv_label('Tasks') }}{% set tc = job_task_count.get(job.id, 0) if job_task_count is defined else 0 %}<div style="color:var(--text);">{{ tc }} attack{{ '' if tc == 1 else 's' }} queued</div></div>
            <div>{{ kv_label('Started') }}<div class="mono" style="color:var(--text);">{{ job.started_at.strftime('%b %d %H:%M') if job.started_at else 'Not started' }}</div></div>
            <div>{{ kv_label('Runtime') }}<div class="mono" style="color:var(--text);">{{ job_runtime.get(job.id, '-') if job_runtime is defined else '-' }}</div></div>
        </div>

        <div style="margin-top:20px;">
            {{ kv_label('Notifications') }}
            {% set nf = job_notifs.get(job.id) if job_notifs is defined else none %}
            {% if nf and (nf.email or nf.pushover or nf.per_hash) %}
            <div style="display:flex; gap:8px; flex-wrap:wrap;">
                {% if nf.email %}<span class="badge green">{{ icon('mail', size=12) }} EMAIL ON COMPLETION</span>{% endif %}
                {% if nf.pushover %}<span class="badge green">{{ icon('bell', size=12) }} PUSHOVER ON COMPLETION</span>{% endif %}
                {% if nf.per_hash %}<span class="badge green">{{ icon('key', size=12) }} PER-HASH ALERTS</span>{% endif %}
            </div>
            {% else %}
            <div class="mono" style="color:var(--text-mute);">none configured</div>
            {% endif %}
        </div>
    </div>
    <div class="hv-dialog-foot">
        <span class="mono" style="font-size:11.5px; color:var(--text-mute); margin-right:auto;">created {{ job.created_at.strftime('%b %d %H:%M') if job.created_at else '—' }}</span>
        <button class="btn" onclick="this.closest('dialog').close()">Close</button>
        <a class="btn btn-primary" href="{{ url_for('jobs.jobs_list_tasks', job_id=job.id) }}" role="button">{{ icon('arrowRight', size=15) }} Open job</a>
    </div>
</dialog>

<dialog class="hv-dialog" id="del-{{ job.id }}">
    <div class="hv-dialog-head"><h3>Delete {{ job.name }}?</h3><button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button></div>
    <div class="hv-dialog-body">This will permanently delete the job. Are you sure you want to continue?</div>
    <div class="hv-dialog-foot">
        <button class="btn" onclick="this.closest('dialog').close()">Back</button>
        <form action="{{ url_for('jobs.jobs_delete', job_id=job.id) }}" method="POST" style="display:inline;">
            <button class="btn btn-danger" type="submit">Delete</button>
        </form>
    </div>
</dialog>
{% endfor %}

{% endblock %}
