{% extends "layout.html.j2" %}
{% from "macros.html.j2" import icon, phos_field %}
{% block title %}Settings · Hashview{% endblock %}
{% block content %}
<script>
    function hvShowSettingsTab(name) {
        var panes = document.querySelectorAll('.hv-settings-pane');
        for (var i = 0; i < panes.length; i++) {
            panes[i].style.display = (panes[i].getAttribute('data-pane') === name) ? 'block' : 'none';
        }
        var tabs = document.querySelectorAll('.hv-settings-tab');
        for (var j = 0; j < tabs.length; j++) {
            if (tabs[j].getAttribute('data-tab') === name) {
                tabs[j].classList.add('active');
            } else {
                tabs[j].classList.remove('active');
            }
        }
    }
</script>

<div class="page-head">
    <div>
        <h1 class="page-title">Settings</h1>
        <div class="page-sub">// global configuration for the application</div>
    </div>
</div>

<div style="display:flex; gap:8px; margin-bottom:16px;">
    <button type="button" class="btn tab-btn hv-settings-tab active" data-tab="hashview" onclick="hvShowSettingsTab('hashview')">{{ icon('settings', size=15) }} Hashview</button>
    <button type="button" class="btn tab-btn hv-settings-tab" data-tab="data" onclick="hvShowSettingsTab('data')">{{ icon('file', size=15) }} Data Management</button>
    <button type="button" class="btn tab-btn hv-settings-tab" data-tab="info" onclick="hvShowSettingsTab('info')">{{ icon('info', size=15) }} Information</button>
</div>

<div class="hv-settings-pane" data-pane="hashview" style="display:block;">
    <form method="POST" action="">
        {{ HashviewForm.hidden_tag() }}
        <div class="card">
            <div class="card-head">{{ icon('settings', size=15) }}<h3>Hashview</h3></div>
            <div class="card-body">

                {{ phos_field(HashviewForm.retention_period) }}

                {{ phos_field(HashviewForm.max_runtime_jobs) }}

                {{ phos_field(HashviewForm.max_runtime_tasks) }}

                <div class="field" style="margin-bottom:0;">
                    <label class="check-row" for="enabledJobWeights" style="margin-bottom:0;">
                        <span class="switch">{{ HashviewForm.enabled_job_weights(id="enabledJobWeights", role="switch") }}<span class="track"></span></span>
                        <span>{{ HashviewForm.enabled_job_weights.label.text }}</span>
                    </label>
                    {% if HashviewForm.enabled_job_weights.errors %}
                        <div class="invalid-feedback" style="display:block;">
                            {% for error in HashviewForm.enabled_job_weights.errors %}
                                <span>{{ error }}</span>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

            </div>
        </div>
        <div class="wizard-nav">
            <a class="btn" href="{{ url_for('users.send_test_email') }}" role="button">{{ icon('mail', size=15) }} Test Email</a>
            <span class="spacer"></span>
            {{ HashviewForm.submit(class="btn btn-primary") }}
        </div>
    </form>
</div>

<div class="hv-settings-pane" data-pane="data" style="display:none;">
    <div class="card">
        <div class="card-head">{{ icon('file', size=15) }}<h3>Data Management</h3></div>
        <table class="tbl">
            <thead><tr><th>Item</th><th class="num">Size</th><th class="center" style="width:120px;">Control</th></tr></thead>
            <tbody>
                <tr>
                    <td style="font-weight:500;">Clear Temp Folder</td>
                    <td class="num">{{ tmp_folder_size }} bytes</td>
                    <td class="center">
                        <div style="display:flex; gap:4px; justify-content:center;">
                            <a class="icon-btn act-del" href="{{ url_for('settings.clear_temp_folder') }}" title="Clear Temp" role="button">{{ icon('trash', size=15) }}</a>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="hv-settings-pane" data-pane="info" style="display:none;">
    <div class="card">
        <div class="card-head">{{ icon('info', size=15) }}<h3>Information</h3></div>
        <div class="card-body">
            <dl style="display:grid; grid-template-columns:180px 1fr; gap:9px 14px; margin:0;">
                <dt class="mono" style="color:var(--text-mute); text-transform:uppercase; font-size:11px; letter-spacing:0.5px;">Application Version</dt>
                <dd class="mono" style="margin:0; color:var(--text);">{{ application_version }}</dd>

                <dt class="mono" style="color:var(--text-mute); text-transform:uppercase; font-size:11px; letter-spacing:0.5px;">Database Version</dt>
                <dd class="mono" style="margin:0; color:var(--text);">{{ database_version }}</dd>
            </dl>
        </div>
    </div>
</div>

{% endblock content %}
