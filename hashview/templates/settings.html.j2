{% extends "layout.html.j2" %}
{% from "macros.html.j2" import icon, phos_field %}
{% block title %}Settings · Hashview{% endblock %}
{% block content %}
<style>
.set-tab { display:flex; align-items:center; gap:10px; width:100%; padding:10px 12px; margin-bottom:4px; border-radius:8px; background:none; border:1px solid transparent; color:var(--text-dim); cursor:pointer; font-family:var(--sans); font-size:13px; text-align:left; }
.set-tab:hover { color:var(--text); background:var(--surface-2); }
.set-tab.active { color:var(--primary); background:rgba(var(--primary-rgb),0.08); border-color:var(--primary-dim); }
.set-tab .ico { width:16px; height:16px; flex:none; }
</style>
<script>
    function hvShowSettingsTab(name) {
        document.querySelectorAll('.hv-settings-pane').forEach(function (p) { p.style.display = (p.getAttribute('data-pane') === name) ? 'block' : 'none'; });
        document.querySelectorAll('.hv-settings-tab').forEach(function (t) { t.classList.toggle('active', t.getAttribute('data-tab') === name); });
    }
    function hvSettingsPlaceholder(btn) {
        var n = btn.nextElementSibling;
        if (n && n.classList && n.classList.contains('hv-placeholder-note')) n.style.display = 'inline';
    }
</script>

<div class="page-head">
    <div>
        <h1 class="page-title">Settings</h1>
        <div class="page-sub">// instance configuration</div>
    </div>
    <button type="submit" form="hv-general-form" class="btn btn-primary">{{ icon('check', size=15) }} Save changes</button>
</div>

<div style="display:flex; gap:var(--gap); align-items:flex-start;">
    {# ---------- left tab nav ---------- #}
    <div class="card" style="flex:none; width:210px; padding:8px;">
        <button type="button" class="set-tab hv-settings-tab active" data-tab="general" onclick="hvShowSettingsTab('general')">{{ icon('settings', size=16) }}<span>General</span></button>
        <button type="button" class="set-tab hv-settings-tab" data-tab="data" onclick="hvShowSettingsTab('data')">{{ icon('file', size=16) }}<span>Data management</span></button>
        <button type="button" class="set-tab hv-settings-tab" data-tab="info" onclick="hvShowSettingsTab('info')">{{ icon('info', size=16) }}<span>Information</span></button>
    </div>

    {# ---------- content ---------- #}
    <div style="flex:1; min-width:0;">

        {# ---- General (the former "Hashview" tab) ---- #}
        <form method="POST" action="" id="hv-general-form" style="margin:0;">
            {{ HashviewForm.hidden_tag() }}
            <div class="hv-settings-pane" data-pane="general" style="display:block;">
                <div class="card">
                    <div class="card-body">
                        <div class="field">
                            <label class="field-label" for="set-retention">Retention period <span class="mono" style="color:var(--text-mute); font-weight:400;">· days</span></label>
                            {{ HashviewForm.retention_period(class="input", type="number", min="1", max="65535", id="set-retention", style="max-width:220px;") }}
                            <span class="field-hint">Auto-purge cracked results and logs after this many days.</span>
                            {% for e in HashviewForm.retention_period.errors %}<div class="invalid-feedback" style="display:block;">{{ e }}</div>{% endfor %}
                        </div>

                        <div class="grid" style="grid-template-columns:1fr 1fr; gap:16px;">
                            <div class="field" style="margin-bottom:0;">
                                <label class="field-label" for="set-jobrt">Max runtime per job <span class="mono" style="color:var(--text-mute); font-weight:400;">· hours</span></label>
                                {{ HashviewForm.max_runtime_jobs(class="input", type="number", min="0", max="65535", id="set-jobrt") }}
                                <span class="field-hint">0 = unlimited.</span>
                            </div>
                            <div class="field" style="margin-bottom:0;">
                                <label class="field-label" for="set-taskrt">Max runtime per task <span class="mono" style="color:var(--text-mute); font-weight:400;">· hours</span></label>
                                {{ HashviewForm.max_runtime_tasks(class="input", type="number", min="0", max="65535", id="set-taskrt") }}
                                <span class="field-hint">0 = unlimited.</span>
                            </div>
                        </div>

                        <div style="display:flex; align-items:center; gap:12px; margin-top:20px;">
                            <div style="flex:1; min-width:0;">
                                <div style="color:var(--text);">Job priority weighting</div>
                                <div class="field-hint" style="margin-top:2px;">Allow operators to set job priority during job creation.</div>
                            </div>
                            <label class="switch">{{ HashviewForm.enabled_job_weights(role="switch") }}<span class="track"></span></label>
                        </div>

                        {# ---- Web crawler (the (DYNAMIC) Website Keywords wordlist) ---- #}
                        <div style="height:1px; background:var(--border-soft); margin:22px 0 16px;"></div>
                        <div class="mono" style="font-size:10px; letter-spacing:1px; text-transform:uppercase; color:var(--text-mute); margin-bottom:14px;">Web crawler · (DYNAMIC) Website Keywords</div>

                        <div class="field">
                            <label class="field-label" for="set-crawl-ua">Crawler user-agent</label>
                            {{ HashviewForm.crawl_user_agent(class="input", id="set-crawl-ua") }}
                            <span class="field-hint">HTTP User-Agent the crawler sends when scraping a target site.</span>
                            {% for e in HashviewForm.crawl_user_agent.errors %}<div class="invalid-feedback" style="display:block;">{{ e }}</div>{% endfor %}
                        </div>

                        <div class="grid" style="grid-template-columns:1fr 1fr 1fr; gap:16px;">
                            <div class="field" style="margin-bottom:0;">
                                <label class="field-label" for="set-crawl-minlen">Min word length <span class="mono" style="color:var(--text-mute); font-weight:400;">· chars</span></label>
                                {{ HashviewForm.crawl_min_word_length(class="input", type="number", min="1", max="65535", id="set-crawl-minlen") }}
                                <span class="field-hint">Discard shorter words.</span>
                                {% for e in HashviewForm.crawl_min_word_length.errors %}<div class="invalid-feedback" style="display:block;">{{ e }}</div>{% endfor %}
                            </div>
                            <div class="field" style="margin-bottom:0;">
                                <label class="field-label" for="set-crawl-depth">Crawl depth <span class="mono" style="color:var(--text-mute); font-weight:400;">· levels</span></label>
                                {{ HashviewForm.crawl_depth(class="input", type="number", min="1", max="100", id="set-crawl-depth") }}
                                <span class="field-hint">Link levels to follow.</span>
                                {% for e in HashviewForm.crawl_depth.errors %}<div class="invalid-feedback" style="display:block;">{{ e }}</div>{% endfor %}
                            </div>
                            <div class="field" style="margin-bottom:0;">
                                <label class="field-label" for="set-crawl-threads">Threads <span class="mono" style="color:var(--text-mute); font-weight:400;">· workers</span></label>
                                {{ HashviewForm.crawl_threads(class="input", type="number", min="1", max="256", id="set-crawl-threads") }}
                                <span class="field-hint">Concurrent fetches.</span>
                                {% for e in HashviewForm.crawl_threads.errors %}<div class="invalid-feedback" style="display:block;">{{ e }}</div>{% endfor %}
                            </div>
                        </div>

                        <div style="display:flex; align-items:center; gap:12px; margin-top:20px;">
                            <div style="flex:1; min-width:0;">
                                <div style="color:var(--text);">Force lowercase</div>
                                <div class="field-hint" style="margin-top:2px;">Convert every crawled word to lowercase before saving.</div>
                            </div>
                            <label class="switch">{{ HashviewForm.crawl_force_lowercase(role="switch") }}<span class="track"></span></label>
                        </div>

                        <div style="height:1px; background:var(--border-soft); margin:20px 0 14px;"></div>
                        <a class="btn" href="{{ url_for('users.send_test_email') }}" role="button">{{ icon('mail', size=15) }} Send test email</a>
                    </div>
                </div>
            </div>
        </form>

        {# ---- Data management ---- #}
        <div class="hv-settings-pane" data-pane="data" style="display:none;">
            <div class="card">
                <div class="card-body">
                    {# Back up database (placeholder — no backend yet) #}
                    <div style="display:flex; align-items:center; gap:14px;">
                        <div style="flex:1; min-width:0;">
                            <div style="color:var(--text); font-weight:500;">Back up database</div>
                            <div class="field-hint" style="margin-top:2px;">Export a full snapshot of the Hashview database.</div>
                        </div>
                        <button type="button" class="btn" onclick="hvSettingsPlaceholder(this)">{{ icon('download', size=15) }} Back up database</button>
                        <span class="mono hv-placeholder-note" style="display:none; color:var(--text-mute); font-size:11.5px;">Not yet implemented.</span>
                    </div>

                    <div style="height:1px; background:var(--border-soft); margin:18px 0;"></div>

                    {# Clear temp folder (existing, real) #}
                    <div style="display:flex; align-items:center; gap:14px;">
                        <div style="flex:1; min-width:0;">
                            <div style="color:var(--text); font-weight:500;">Clear temp folder</div>
                            <div class="field-hint" style="margin-top:2px;">Remove temporary working files · currently {{ tmp_folder_size }}.</div>
                        </div>
                        <a class="btn" href="{{ url_for('settings.clear_temp_folder') }}" role="button">{{ icon('trash', size=15) }} Clear temp</a>
                    </div>
                </div>
            </div>

            {# Danger zone — purge all cracked passwords (placeholder — no backend yet) #}
            <div class="card" style="margin-top:var(--gap); border-color:var(--red-dim);">
                <div class="card-body">
                    <div style="display:flex; align-items:center; gap:8px; color:var(--red); font-weight:600; margin-bottom:8px;">{{ icon('ban', size=15) }} Danger zone</div>
                    <div class="field-hint" style="margin-bottom:14px;">Permanently wipe all recovered plaintext from the database. This cannot be undone.</div>
                    <button type="button" class="btn btn-danger" onclick="hvSettingsPlaceholder(this)">{{ icon('trash', size=15) }} Purge all cracked passwords</button>
                    <span class="mono hv-placeholder-note" style="display:none; margin-left:12px; color:var(--text-mute); font-size:11.5px;">Not yet implemented.</span>
                </div>
            </div>
        </div>

        {# ---- Information ---- #}
        <div class="hv-settings-pane" data-pane="info" style="display:none;">
            <div class="card">
                <div class="card-body">
                    <dl style="display:grid; grid-template-columns:200px 1fr; gap:12px 14px; margin:0;">
                        <dt class="mono" style="color:var(--text-mute); text-transform:uppercase; font-size:10px; letter-spacing:1px;">Application version</dt>
                        <dd class="mono" style="margin:0; color:var(--text);">{{ application_version }}</dd>
                        <dt class="mono" style="color:var(--text-mute); text-transform:uppercase; font-size:10px; letter-spacing:1px;">Database version</dt>
                        <dd class="mono" style="margin:0; color:var(--text);">{{ database_version }}</dd>
                    </dl>
                </div>
            </div>
        </div>

    </div>
</div>

{% endblock content %}
