{% extends "layout.html.j2" %}
{% from "macros.html.j2" import icon, phos_field %}
{% block title %}Settings · Hashview{% endblock %}
{% block content %}
<style>
.set-tab { display:flex; align-items:center; gap:10px; width:100%; padding:10px 12px; margin-bottom:4px; border-radius:8px; background:none; border:1px solid transparent; color:var(--text-dim); cursor:pointer; font-family:var(--sans); font-size:13px; text-align:left; }
.set-tab:hover { color:var(--text); background:var(--surface-2); }
.set-tab.active { color:var(--primary); background:rgba(var(--primary-rgb),0.08); border-color:var(--primary-dim); }
.set-tab .ico { width:16px; height:16px; flex:none; }
</style>
<script>
    function hvShowSettingsTab(name) {
        document.querySelectorAll('.hv-settings-pane').forEach(function (p) { p.style.display = (p.getAttribute('data-pane') === name) ? 'block' : 'none'; });
        document.querySelectorAll('.hv-settings-tab').forEach(function (t) { t.classList.toggle('active', t.getAttribute('data-tab') === name); });
    }
    function hvSettingsPlaceholder(btn) {
        var n = btn.nextElementSibling;
        if (n && n.classList && n.classList.contains('hv-placeholder-note')) n.style.display = 'inline';
    }
    // Grey out + make non-interactible a notification channel's settings when its
    // master toggle is off. Inputs use readonly (not disabled) so their values
    // still POST — disabling Slack must not wipe the saved bot token.
    function hvSyncNotif(channel) {
        var ids = { email: 'email_enabled', push: 'pushover_enabled', slack: 'slack_enabled' };
        var toggle = document.getElementById(ids[channel]);
        var section = document.getElementById('notif-' + channel);
        if (!toggle || !section) return;
        var body = section.querySelector('.notif-body');
        if (!body) return;
        var on = toggle.checked;
        body.style.opacity = on ? '' : '0.4';
        body.style.pointerEvents = on ? '' : 'none';
        body.querySelectorAll('input, textarea, select').forEach(function (el) {
            if (on) { el.removeAttribute('readonly'); } else { el.setAttribute('readonly', 'readonly'); }
        });
        body.querySelectorAll('a, button').forEach(function (el) {
            el.setAttribute('tabindex', on ? '0' : '-1');
            el.setAttribute('aria-disabled', on ? 'false' : 'true');
        });
    }
    document.addEventListener('DOMContentLoaded', function () {
        ['email', 'push', 'slack'].forEach(hvSyncNotif);
    });
</script>

<div class="page-head">
    <div>
        <h1 class="page-title">Settings</h1>
        <div class="page-sub">// instance configuration</div>
    </div>
    <button type="submit" form="hv-general-form" class="btn btn-primary">{{ icon('check', size=15) }} Save changes</button>
</div>

<div style="display:flex; gap:var(--gap); align-items:flex-start;">
    {# ---------- left tab nav ---------- #}
    <div class="card" style="flex:none; width:210px; padding:8px;">
        <button type="button" class="set-tab hv-settings-tab active" data-tab="general" onclick="hvShowSettingsTab('general')">{{ icon('settings', size=16) }}<span>General</span></button>
        <button type="button" class="set-tab hv-settings-tab" data-tab="notifications" onclick="hvShowSettingsTab('notifications')">{{ icon('bell', size=16) }}<span>Notifications</span></button>
        <button type="button" class="set-tab hv-settings-tab" data-tab="data" onclick="hvShowSettingsTab('data')">{{ icon('file', size=16) }}<span>Data management</span></button>
        <button type="button" class="set-tab hv-settings-tab" data-tab="info" onclick="hvShowSettingsTab('info')">{{ icon('info', size=16) }}<span>Information</span></button>
    </div>

    {# ---------- content ---------- #}
    <div style="flex:1; min-width:0;">

        {# ---- General (the former "Hashview" tab) ---- #}
        <form method="POST" action="" id="hv-general-form" style="margin:0;">
            {{ HashviewForm.hidden_tag() }}
            <div class="hv-settings-pane" data-pane="general" style="display:block;">
                <div class="card">
                    <div class="card-body">
                        <div class="field">
                            <label class="field-label" for="set-retention">Retention period <span class="mono" style="color:var(--text-mute); font-weight:400;">· days</span></label>
                            {{ HashviewForm.retention_period(class="input", type="number", min="1", max="65535", id="set-retention", style="max-width:220px;") }}
                            <span class="field-hint">Auto-purge cracked results and logs after this many days.</span>
                            {% for e in HashviewForm.retention_period.errors %}<div class="invalid-feedback" style="display:block;">{{ e }}</div>{% endfor %}
                        </div>

                        <div class="grid" style="grid-template-columns:1fr 1fr; gap:16px;">
                            <div class="field" style="margin-bottom:0;">
                                <label class="field-label" for="set-jobrt">Max runtime per job <span class="mono" style="color:var(--text-mute); font-weight:400;">· hours</span></label>
                                {{ HashviewForm.max_runtime_jobs(class="input", type="number", min="0", max="65535", id="set-jobrt") }}
                                <span class="field-hint">0 = unlimited.</span>
                            </div>
                            <div class="field" style="margin-bottom:0;">
                                <label class="field-label" for="set-taskrt">Max runtime per task <span class="mono" style="color:var(--text-mute); font-weight:400;">· hours</span></label>
                                {{ HashviewForm.max_runtime_tasks(class="input", type="number", min="0", max="65535", id="set-taskrt") }}
                                <span class="field-hint">0 = unlimited.</span>
                            </div>
                        </div>

                        <div style="display:flex; align-items:center; gap:12px; margin-top:20px;">
                            <div style="flex:1; min-width:0;">
                                <div style="color:var(--text);">Job priority weighting</div>
                                <div class="field-hint" style="margin-top:2px;">Allow operators to set job priority during job creation.</div>
                            </div>
                            <label class="switch">{{ HashviewForm.enabled_job_weights(role="switch") }}<span class="track"></span></label>
                        </div>

                        {# ---- Web crawler (the (DYNAMIC) Website Keywords wordlist) ---- #}
                        <div style="height:1px; background:var(--border-soft); margin:22px 0 16px;"></div>
                        <div class="mono" style="font-size:10px; letter-spacing:1px; text-transform:uppercase; color:var(--text-mute); margin-bottom:14px;">Web crawler · (DYNAMIC) Website Keywords</div>

                        <div class="field">
                            <label class="field-label" for="set-crawl-ua">Crawler user-agent</label>
                            {{ HashviewForm.crawl_user_agent(class="input", id="set-crawl-ua") }}
                            <span class="field-hint">HTTP User-Agent the crawler sends when scraping a target site.</span>
                            {% for e in HashviewForm.crawl_user_agent.errors %}<div class="invalid-feedback" style="display:block;">{{ e }}</div>{% endfor %}
                        </div>

                        <div class="grid" style="grid-template-columns:1fr 1fr 1fr; gap:16px;">
                            <div class="field" style="margin-bottom:0;">
                                <label class="field-label" for="set-crawl-minlen">Min word length <span class="mono" style="color:var(--text-mute); font-weight:400;">· chars</span></label>
                                {{ HashviewForm.crawl_min_word_length(class="input", type="number", min="1", max="65535", id="set-crawl-minlen") }}
                                <span class="field-hint">Discard shorter words.</span>
                                {% for e in HashviewForm.crawl_min_word_length.errors %}<div class="invalid-feedback" style="display:block;">{{ e }}</div>{% endfor %}
                            </div>
                            <div class="field" style="margin-bottom:0;">
                                <label class="field-label" for="set-crawl-depth">Crawl depth <span class="mono" style="color:var(--text-mute); font-weight:400;">· levels</span></label>
                                {{ HashviewForm.crawl_depth(class="input", type="number", min="1", max="100", id="set-crawl-depth") }}
                                <span class="field-hint">Link levels to follow.</span>
                                {% for e in HashviewForm.crawl_depth.errors %}<div class="invalid-feedback" style="display:block;">{{ e }}</div>{% endfor %}
                            </div>
                            <div class="field" style="margin-bottom:0;">
                                <label class="field-label" for="set-crawl-threads">Threads <span class="mono" style="color:var(--text-mute); font-weight:400;">· workers</span></label>
                                {{ HashviewForm.crawl_threads(class="input", type="number", min="1", max="256", id="set-crawl-threads") }}
                                <span class="field-hint">Concurrent fetches.</span>
                                {% for e in HashviewForm.crawl_threads.errors %}<div class="invalid-feedback" style="display:block;">{{ e }}</div>{% endfor %}
                            </div>
                        </div>

                        <div style="display:flex; align-items:center; gap:12px; margin-top:20px;">
                            <div style="flex:1; min-width:0;">
                                <div style="color:var(--text);">Force lowercase</div>
                                <div class="field-hint" style="margin-top:2px;">Convert every crawled word to lowercase before saving.</div>
                            </div>
                            <label class="switch">{{ HashviewForm.crawl_force_lowercase(role="switch") }}<span class="track"></span></label>
                        </div>
                    </div>
                </div>
            </div>

            {# ---- Notifications (channel master switches) ---- #}
            <div class="hv-settings-pane" data-pane="notifications" style="display:none;">
                <div class="card">
                    <div class="card-body">
                        <span class="field-hint" style="margin-top:0; display:block; margin-bottom:18px;">Master switch for each notification channel. A disabled channel is hidden during job creation and in every user's profile, and never sends — its settings below are greyed out until re-enabled.</span>

                        {# EMAIL #}
                        <div class="notif-channel" id="notif-email">
                            <div style="display:flex; align-items:center; gap:12px;">
                                <div style="flex:1; min-width:0;">
                                    <div style="color:var(--text); display:flex; align-items:center; gap:8px;">{{ icon('mail', size=16) }} Email notifications</div>
                                    <div class="field-hint" style="margin-top:2px;">Delivered via the configured SMTP server to each user's account email address.</div>
                                </div>
                                <label class="switch">{{ HashviewForm.email_enabled(role="switch", onchange="hvSyncNotif('email')") }}<span class="track"></span></label>
                            </div>
                            <div class="notif-body" style="margin-top:14px;">
                                <a class="btn" href="{{ url_for('users.send_test_email') }}" role="button">{{ icon('mail', size=15) }} Send test email</a>
                            </div>
                        </div>

                        <div style="height:1px; background:var(--border-soft); margin:20px 0;"></div>

                        {# PUSHOVER #}
                        <div class="notif-channel" id="notif-push">
                            <div style="display:flex; align-items:center; gap:12px;">
                                <div style="flex:1; min-width:0;">
                                    <div style="color:var(--text); display:flex; align-items:center; gap:8px;">{{ icon('bell', size=16) }} Pushover notifications</div>
                                    <div class="field-hint" style="margin-top:2px;">Mobile push — each user enters their own Pushover user key &amp; app token under account settings.</div>
                                </div>
                                <label class="switch">{{ HashviewForm.pushover_enabled(role="switch", onchange="hvSyncNotif('push')") }}<span class="track"></span></label>
                            </div>
                        </div>

                        <div style="height:1px; background:var(--border-soft); margin:20px 0;"></div>

                        {# SLACK #}
                        <div class="notif-channel" id="notif-slack">
                            <div style="display:flex; align-items:center; gap:12px;">
                                <div style="flex:1; min-width:0;">
                                    <div style="color:var(--text); display:flex; align-items:center; gap:8px;">{{ icon('slack', size=16) }} Slack notifications</div>
                                    <div class="field-hint" style="margin-top:2px;">The Hashview bot DMs each user — each user sets their Slack Member ID under account settings.</div>
                                </div>
                                <label class="switch">{{ HashviewForm.slack_enabled(role="switch", onchange="hvSyncNotif('slack')") }}<span class="track"></span></label>
                            </div>
                            <div class="notif-body" style="margin-top:18px;">
                                <div class="field" style="margin-bottom:0;">
                                    <label class="field-label" for="set-slack-token">Bot user OAuth token</label>
                                    {{ HashviewForm.slack_bot_token(class="input mono", id="set-slack-token", placeholder="xoxb-…", autocomplete="off") }}
                                    <span class="field-hint">Create a Slack app, add the <span class="mono">chat:write</span> + <span class="mono">im:write</span> bot scopes, install it to your workspace, and paste the Bot User OAuth Token here.</span>
                                    {% for e in HashviewForm.slack_bot_token.errors %}<div class="invalid-feedback" style="display:block;">{{ e }}</div>{% endfor %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>

        {# ---- Data management ---- #}
        <div class="hv-settings-pane" data-pane="data" style="display:none;">
            <div class="card">
                <div class="card-body">
                    {# Back up database (mysqldump -> gz -> AES-256 encrypted with a one-time password) #}
                    <div style="display:flex; align-items:center; gap:14px;">
                        <div style="flex:1; min-width:0;">
                            <div style="color:var(--text); font-weight:500;">Back up database</div>
                            <div class="field-hint" style="margin-top:2px;">Export a full snapshot of the Hashview database — gzip-compressed and AES-256 encrypted with a one-time password shown to you once.</div>
                        </div>
                        <form id="hv-backup-form" style="display:none;">{{ backupForm.hidden_tag() }}</form>
                        <button type="button" class="btn" id="hv-backup-btn" onclick="hvBackupDb()">{{ icon('download', size=15) }} Back up database</button>
                    </div>

                    <div style="height:1px; background:var(--border-soft); margin:18px 0;"></div>

                    {# Clear temp folder (existing, real) #}
                    <div style="display:flex; align-items:center; gap:14px;">
                        <div style="flex:1; min-width:0;">
                            <div style="color:var(--text); font-weight:500;">Clear temp folder</div>
                            <div class="field-hint" style="margin-top:2px;">Remove temporary working files · currently {{ tmp_folder_size }}.</div>
                        </div>
                        <a class="btn" href="{{ url_for('settings.clear_temp_folder') }}" role="button">{{ icon('trash', size=15) }} Clear temp</a>
                    </div>
                </div>
            </div>

            {# Danger zone — purge all cracked passwords (placeholder — no backend yet) #}
            <div class="card" style="margin-top:var(--gap); border-color:var(--red-dim);">
                <div class="card-body">
                    <div style="display:flex; align-items:center; gap:8px; color:var(--red); font-weight:600; margin-bottom:8px;">{{ icon('ban', size=15) }} Danger zone</div>
                    <div class="field-hint" style="margin-bottom:14px;">Permanently wipe all recovered plaintext from the database — every cracked hash is reset to uncracked (the hashes themselves are kept). This cannot be undone.</div>
                    <form method="POST" action="{{ url_for('settings.purge_cracked') }}" style="margin:0;"
                          onsubmit="return confirm('Permanently wipe ALL recovered plaintext from the database? Every cracked hash will be reset to uncracked. This cannot be undone.');">
                        <button type="submit" class="btn btn-danger">{{ icon('trash', size=15) }} Purge all cracked passwords</button>
                    </form>
                </div>
            </div>
        </div>

        {# ---- Information ---- #}
        <div class="hv-settings-pane" data-pane="info" style="display:none;">
            <div class="card">
                <div class="card-body">
                    <dl style="display:grid; grid-template-columns:200px 1fr; gap:12px 14px; margin:0;">
                        <dt class="mono" style="color:var(--text-mute); text-transform:uppercase; font-size:10px; letter-spacing:1px;">Application version</dt>
                        <dd class="mono" style="margin:0; color:var(--text);">{{ application_version }}</dd>
                        <dt class="mono" style="color:var(--text-mute); text-transform:uppercase; font-size:10px; letter-spacing:1px;">Database version</dt>
                        <dd class="mono" style="margin:0; color:var(--text);">{{ database_version }}</dd>
                    </dl>
                </div>
            </div>
        </div>

    </div>
</div>

{# ---- database backup modal ---- #}
<dialog class="hv-dialog" id="backup-modal" style="max-width:640px; width:94vw;" oncancel="hvBackupOnCancel(event)">
    <div class="hv-dialog-head">
        {{ icon('download', size=16) }}
        <div style="line-height:1.2;">
            <h3 style="margin:0;">Database backup</h3>
            <div class="mono" style="font-size:10px; letter-spacing:0.5px; text-transform:uppercase; color:var(--text-mute); margin-top:3px;">encrypted mysqldump · one-time password</div>
        </div>
        <button type="button" class="icon-btn" id="bk-close" onclick="this.closest('dialog').close()" aria-label="Close" style="margin-left:auto;">{{ icon('x', size=15) }}</button>
    </div>
    <div class="hv-dialog-body">
        {# busy state #}
        <style>@keyframes hvBkIndet { 0%{margin-left:-38%;} 100%{margin-left:100%;} }</style>
        <div id="bk-busy">
            <div class="mono" style="color:var(--text-dim); font-size:12.5px; margin-bottom:12px;">Generating encrypted backup on the server — large databases can take a while…</div>
            <div style="height:6px; border-radius:3px; background:var(--surface-3); overflow:hidden;"><div id="bk-bar" style="height:100%; width:38%; border-radius:3px; background:linear-gradient(90deg,var(--primary-deep),var(--primary)); box-shadow:var(--glow-sm); animation:hvBkIndet 1.1s ease-in-out infinite;"></div></div>
        </div>
        {# error state #}
        <div id="bk-error" class="invalid-feedback" style="display:none;"></div>
        {# success state #}
        <div id="bk-success" style="display:none;">
            <div style="color:var(--text); font-weight:600; display:flex; align-items:center; gap:8px; margin-bottom:6px;">{{ icon('checkCircle', size=16) }} Backup ready</div>
            <div class="field-hint" style="margin-bottom:14px;">Download the encrypted backup and store the one-time password somewhere safe. <b>The password is shown only once</b> and is required to decrypt the file — Hashview does not keep a copy.</div>

            <div class="mono" style="font-size:9.5px; letter-spacing:1px; text-transform:uppercase; color:var(--text-mute); margin-bottom:6px;">One-time decryption password</div>
            <div style="display:flex; gap:8px; align-items:stretch; margin-bottom:16px;">
                <input class="input mono" id="bk-password" type="text" readonly style="flex:1; min-width:0;">
                <button type="button" class="btn" onclick="hvBackupCopy()" style="flex:none;">{{ icon('copy', size=15) }} Copy</button>
            </div>

            <div class="mono" style="font-size:9.5px; letter-spacing:1px; text-transform:uppercase; color:var(--text-mute); margin-bottom:6px;">Decrypt instructions</div>
            <pre id="bk-instructions" class="mono" style="background:var(--surface-2); border:1px solid var(--border-soft); border-radius:8px; padding:12px 14px; font-size:11.5px; color:var(--text-dim); overflow-x:auto; white-space:pre; margin:0 0 12px;"></pre>
            <div class="mono" style="font-size:11px; color:var(--text-mute); margin-bottom:4px;">SHA-256 (verify with <span class="mono">sha256sum</span>):</div>
            <div class="mono" id="bk-sha" style="font-size:10.5px; color:var(--text-dim); word-break:break-all; margin-bottom:4px;"></div>
        </div>
    </div>
    <div class="hv-dialog-foot">
        <button type="button" class="btn" id="bk-cancel" onclick="document.getElementById('backup-modal').close()">Close</button>
        <a class="btn btn-primary" id="bk-download" href="#" style="display:none;" download>{{ icon('download', size=15) }} Download backup</a>
    </div>
</dialog>
<script>
    var hvBackupBusy = false;
    function hvBackupOnCancel(e){ if (hvBackupBusy) e.preventDefault(); }   // block Esc while generating
    function hvBackupCopy(){
        var i = document.getElementById('bk-password');
        if (!i || !i.value) return;
        if (navigator.clipboard) { navigator.clipboard.writeText(i.value); }
        else { i.select(); document.execCommand('copy'); }
    }
    function hvBackupDb(){
        if (hvBackupBusy) return;
        var modal = document.getElementById('backup-modal');
        document.getElementById('bk-busy').style.display = 'block';
        document.getElementById('bk-error').style.display = 'none';
        document.getElementById('bk-success').style.display = 'none';
        document.getElementById('bk-download').style.display = 'none';
        document.getElementById('bk-close').style.display = 'none';
        document.getElementById('bk-cancel').disabled = true;     // can't dismiss mid-generation (would lose the one-time password)
        document.getElementById('hv-backup-btn').disabled = true;
        hvBackupBusy = true;
        if (typeof modal.showModal === 'function') { modal.showModal(); } else { modal.setAttribute('open',''); }

        fetch("{{ url_for('settings.settings_backup') }}", {
            method: 'POST',
            headers: { 'X-Requested-With': 'fetch' },
            body: new FormData(document.getElementById('hv-backup-form')),
        }).then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
          .then(function (res) {
            hvBackupBusy = false;
            document.getElementById('bk-busy').style.display = 'none';
            document.getElementById('bk-close').style.display = '';
            document.getElementById('bk-cancel').disabled = false;
            document.getElementById('hv-backup-btn').disabled = false;
            if (res.ok && res.d && res.d.status === 'ok') {
                document.getElementById('bk-password').value = res.d.password || '';
                document.getElementById('bk-instructions').textContent = (res.d.instructions || []).join('\n');
                document.getElementById('bk-sha').textContent = res.d.sha256 || '';
                var dl = document.getElementById('bk-download');
                dl.href = res.d.download_url;
                if (res.d.download_name) dl.setAttribute('download', res.d.download_name);
                dl.style.display = '';
                document.getElementById('bk-success').style.display = 'block';
            } else {
                var err = document.getElementById('bk-error');
                err.textContent = (res.d && res.d.msg) ? res.d.msg : 'Backup failed.';
                err.style.display = 'block';
            }
          }).catch(function () {
            hvBackupBusy = false;
            document.getElementById('bk-busy').style.display = 'none';
            document.getElementById('bk-close').style.display = '';
            document.getElementById('bk-cancel').disabled = false;
            document.getElementById('hv-backup-btn').disabled = false;
            var err = document.getElementById('bk-error');
            err.textContent = 'Backup request failed (network or server error).';
            err.style.display = 'block';
          });
    }
</script>

{% endblock content %}
