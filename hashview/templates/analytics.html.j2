    </div>
    <div class="card-body" style="max-height: 600px; overflow-y: auto;">
        <table class="tbl">
            <tbody>
                <tr>
                {% set pos = namespace(value=0) %}
                {% for entry in fig9_table %}
                    {% set pos.value = pos.value + 1 %}
                    <td class="mono">{{entry}}</td>
                    {% if pos.value % 3 == 0%}
                        </tr>
                        <tr>
                    {% endif %}
                {% endfor %}
                </tr>
            </tbody>
        </table>
    </div>
</div>
{% endblock content %}
