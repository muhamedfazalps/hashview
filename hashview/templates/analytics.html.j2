<div class="card" style="margin-top:var(--gap);">
    <div class="card-head"><h3>General Stats</h3></div>
    <div class="card-body">
        <table class="tbl">
            <tbody>
                {% if customer_id %}
                <tr>
                    <td>Total Accounts:</td>
                    <td class="num">{{ total_accounts }}</td>
                </tr>
                {% endif %}
                <tr>
                    <td>Total Unique Hashes:</td>
                    <td class="num">{{ total_unique_hashes }}</td>
                </tr>
                {% if customer_id %}
                <tr>
                    <td>Total Runtime:</td>
                    <td class="num">
                        {% if total_runtime > 604800 %}
                            {{ (total_runtime/604800)|round|int }} week(s)<br>
                        {% elif total_runtime > 86400 %}
                            {{ (total_runtime/86400)|round|int }} day(s)<br>
                        {% elif total_runtime > 3600 %}
                            {{ (total_runtime/3600)|round|int }} hour(s)<br>
                        {% elif total_runtime > 60 %}
                            {{ (total_runtime/60)|round|int }} minute(s)<br>
                        {% elif total_runtime < 60 %}
                            < 1 minute<br>
                        {% endif %}
                    </td>
                </tr>
                {% endif %}
                <tr>
                    <td>Download Recovered:</td>
                    <td>
                        {% if customer_id %}
                            {% if hashfile_id %}
                                <a class="btn btn-primary btn-sm" href="/analytics/download?type=found&customer_id={{customer_id}}&hashfile_id={{hashfile_id}}" role="button">Cracked</a>
                            {% else %}
                                <a class="btn btn-primary btn-sm" href="/analytics/download?type=found&customer_id={{customer_id}}" role="button">Cracked</a>
                            {% endif %}
                        {% else %}
                            <a class="btn btn-primary btn-sm" href="/analytics/download?type=found" role="button">Cracked</a>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <td>Download Unrecovered:</td>
                    <td>
                        {% if customer_id %}
                            {% if hashfile_id %}
                                <a class="btn btn-primary btn-sm" href="/analytics/download?type=left&customer_id={{customer_id}}&hashfile_id={{hashfile_id}}" role="button">Uncracked</a>
                            {% else %}
                                <a class="btn btn-primary btn-sm" href="/analytics/download?type=left&customer_id={{customer_id}}" role="button">Uncracked</a>
                            {% endif %}
                        {% else %}
                            <a class="btn btn-primary btn-sm" href="/analytics/download?type=left" role="button">Uncracked</a>
                        {% endif %}
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="card" style="margin-top:var(--gap);">
    <div class="card-head">
        <h3>Passwords Count by Length</h3>
        <a id="passwords_count_len" class="download_btn" role="button" title="Download Chart" style="margin-left:auto;">{{ icon('download', size=15) }}</a>
    </div>
    <div class="card-body">
        <canvas id="PasswordsCountByLength" width="1000" height="300"></canvas>
        <script>
            var ctx = document.getElementById("PasswordsCountByLength").getContext("2d");
            var doughNut = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: {{ fig5_labels | safe }},
                    datasets: [{
                        label: "Password Counts by Lengths",
                        data: {{ fig5_values | safe }},
                        backgroundColor: ['rgba(94, 240, 138, 0.5)']
                    }]
                },
                plugins: [{
                    beforeDraw: function(chart,args,options){
                        const c = chart.ctx
                        c.fillStyle = '#0c0f0d';
                        c.fillRect(0, 0, chart.width, chart.height);
                    }
                }],
                options: {
                    responsive: true, //Resizes the chart canvas when its container does
                    scales: {
                        x: { ticks: { color: '#7c8a76' }, grid: { color: 'rgba(43,53,37,0.5)' } },
                        y: { beginAtZero: true, ticks: { color: '#7c8a76' }, grid: { color: 'rgba(43,53,37,0.5)' } }
                    },
                    plugins: {
                        legend: { display: false },
                        title: {
                            color: '#d2ddca',
                            display: false,
                            text: 'Passwords Count by Length',
                            font: { size: 18, family: 'Arial' },
                            padding: { top: 10, bottom: 20 }
                        }
                    }
                }
            });
            chart_download(4);
        </script>
    </div>
</div>

