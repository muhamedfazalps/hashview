                        }]
                    },
                    options: {
                        responsive: false,
                        plugins: {
                            legend: { position: 'bottom' },
                            title: {
                                color: '#d2ddca',
                                display: false,
                                text: 'Password Complexity',
                                font: { size: 18, family: 'Arial' },
                                padding: { top: 10, bottom: 10 }
                            }
