{% extends "layout.html.j2" %}
{% from "icons.html.j2" import icon %}
{% block title %}Analytics · Hashview{% endblock %}

{% block head %}
{# Self-hosted Chart.js 3.1.0 (offline-safe). NOTE: kept at v3 — analytics' chart JS and the
   extendChart() doughnut monkeypatch target the v3 API; the vendored js/chart.min.js is v2.9.4
   (used by the dashboard) and is NOT API-compatible here, hence the dedicated 3.1.0 file. #}
<script src="{{ url_for('static', filename='js/chart-3.1.0.min.js') }}"></script>
<style>
    .download_btn { color: var(--text-mute); cursor: pointer; }
    .download_btn:hover { color: var(--primary); }
    .analytics-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap); }
    @media (max-width: 900px) { .analytics-grid { grid-template-columns: 1fr; } }
    .analytics-card .card-body { text-align: center; }
    .analytics-card canvas { max-width: 100%; }
    .filter-bar { display: flex; flex-wrap: wrap; align-items: center; gap: 18px; margin-bottom: 22px; }
    .filter-bar .fb-group { display: flex; align-items: center; gap: 9px; }
    .filter-bar .fb-label { font-family: var(--mono); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: var(--text-mute); }
    .filter-bar .select { width: auto; min-width: 190px; }
</style>
<script>
    var dict = { 1: "recovered_accounts", 2: "password_complexity", 3:"composition_makeup", 4:"passwords_count_len", 5:"top_10_passswords"};
    var toggle = false;

    // Phosphor theme defaults for Chart.js v3 (legend labels + axis ticks render light on dark).
    Chart.defaults.color = '#d2ddca';

    extendChart();

    function extendChart() { // add text to the middle of all doughnut charts
        var originalDraw = Chart.controllers.doughnut.prototype.draw;
        Chart.controllers.doughnut.prototype.draw = function (ease) {
            originalDraw.call(this, ease);

            const ctx = this.chart.ctx
            const chartArea = this.chart.chartArea

            //Font style
            const fontStyle = 'normal'
            //matching chart headers
            const fontFamily = `-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,
            'Noto Sans',sans-serif,'Apple Color Emoji','Segoe UI Emoji','Segoe UI Symbol','Noto Color Emoji'`
            const fontSize = chartArea.right / 15
            ctx.font = `${fontStyle} ${fontSize}px ${fontFamily}`
            ctx.fillStyle = '#5ef08a' //Text color (phosphor green)

            //Center text
            ctx.textAlign = 'center'
            ctx.textBaseline = 'middle'
            var value = this.chart.options.percent ? this.chart.options.percent : "";
            ctx.fillText(value, (chartArea.right + chartArea.left) / 2, (chartArea.bottom + chartArea.top) / 2)

            //Set chart background color (phosphor surface) so PNG downloads aren't transparent
            ctx.globalCompositeOperation = 'destination-over';
            ctx.fillStyle = '#0c0f0d';
            ctx.fillRect(0, 0, this.chart.width, this.chart.height);
        };
    }

    function chart_download(id) {
            var chart = doughNut;
            document.getElementById(dict[id]).onclick = function () {
            //The title is not part of the graph canvas so it would not show up in the image download
            //So we add a hidden title, and only show it when downloading the image.
            chart.options.animation.duration = 0;
            chart.options.plugins.title.display = true;
            chart.update();
            //Create a download link
            var a = document.createElement('a');
            a.href = chart.toBase64Image();
            a.download = dict[id] + '.png';
            a.click();
            //Hide the title again
            chart.options.plugins.title.display = false;
            chart.update();
            //Turn back on animations
            chart.options.animation.duration = 1000;
            chart.update();
        };
    }

    function get_chart(id){
        document.getElementById(dict[id]).click();
    }

    function chart_download_all(){
        if(confirm("This will download all charts on the page")){
            for(var i=1;i<6;i++){
                get_chart(i);
            }
        }
    }

    function show_hide(){
        if(toggle){
            document.querySelectorAll('.download_btn').forEach(function(el) {
                el.style.display = 'inline';
            });
            document.getElementById("toggle_btn").style.color = "var(--primary)";
            toggle = false;
        }
        else{
            document.querySelectorAll('.download_btn').forEach(function(el) {
                el.style.display = 'none';
            });
            document.getElementById("toggle_btn").style.color = "var(--text-mute)";
            toggle = true;
        }
    }
</script>
{% endblock head %}

{% block content %}
<div class="page-head">
    <div>
        <h1 class="page-title">Analytics</h1>
        <div class="page-sub">// password recovery statistics{% if customer_id %} · filtered{% endif %}</div>
    </div>
    <div style="display:flex; gap:8px;">
        <button class="btn btn-sm" onclick="chart_download_all()">{{ icon('download', size=14) }} Download All</button>
        <button class="icon-btn" id="toggle_btn" title="Show/Hide per-chart download icons" onclick="show_hide()">{{ icon('download', size=15) }}</button>
    </div>
</div>

<div class="filter-bar">
    <div class="fb-group">
        <span class="fb-label">Customers</span>
        <select class="select" onchange="if(this.value){location.href=this.value}">
            <option value="/analytics"{% if not customer_id %} selected{% endif %}>All Customers</option>
            {% for customer in customers %}
            <option value="/analytics?customer_id={{ customer.id }}"{% if customer_id and customer.id|string() == customer_id|string() %} selected{% endif %}>{{ customer.name }}</option>
            {% endfor %}
        </select>
    </div>
    <div class="fb-group">
        <span class="fb-label">Hashfiles</span>
        {% if customer_id is not none %}
        <select class="select" onchange="if(this.value){location.href=this.value}">
            <option value="/analytics?customer_id={{ customer_id }}"{% if not hashfile_id %} selected{% endif %}>All Hashfiles</option>
            {% for hashfile in hashfiles %}
                {% if hashfile.customer_id|string() == customer_id|string() %}
                <option value="/analytics?customer_id={{ customer_id }}&hashfile_id={{ hashfile.id }}"{% if hashfile_id and hashfile.id|string() == hashfile_id|string() %} selected{% endif %}>{{ hashfile.name }}</option>
                {% endif %}
            {% endfor %}
        </select>
        {% else %}
        <select class="select" disabled><option>N/A</option></select>
        {% endif %}
    </div>
</div>

<div class="analytics-grid">
    <div class="card analytics-card">
        <div class="card-head">
            <h3>Recovered Accounts</h3>
            <a id="recovered_accounts" class="download_btn" role="button" title="Download Chart" style="margin-left:auto;">{{ icon('download', size=15) }}</a>
        </div>
        <div class="card-body">
            <canvas id="TotalCrackedAccountHashes" width="300" height="300"></canvas>
            <script>
                var vis1 = document.getElementById("TotalCrackedAccountHashes").getContext("2d");
                var doughNut = new Chart(vis1, {
                    type: 'doughnut',
                    data: {
                        labels: {{ fig1_labels | safe }},
                        datasets: [{
                            label: "my label",
                            data: {{ fig1_values | safe }},
                            backgroundColor: ['rgba(255, 95, 86, 0.5)', 'rgba(94, 240, 138, 0.5)']
                        }]
                    },
                    options: {
                        percent: {{fig1_percent | safe}}, // Custom variable to store the value in the middle of the chart
                        responsive: false,
                        plugins: {
                            legend: { position: 'bottom' },
                            title: {
                                color: '#d2ddca',
                                display: false,
                                text: 'Recovered Accounts',
                                font: { size: 18, family: 'Arial' },
                                padding: { top: 10, bottom: 20 }
                            }
                        }
                    }
                });
                chart_download(1);
            </script>
        </div>
    </div>
    <div class="card analytics-card">
        <div class="card-head">
