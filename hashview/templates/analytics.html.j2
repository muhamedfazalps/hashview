</div>

<div class="card" style="margin-top:var(--gap);">
    <div class="card-head"><h3>Top 10 Masks</h3></div>
    <div class="card-body">
        <table class="tbl">
            <thead>
                <tr>
                    <th>Mask</th>
                    <th>Total</th>
                    <th>Percentage</th>
                </tr>
            </thead>
            <tbody>
                {% for entry in fig7_values %}
                <tr>
                    <td class="mono">{{entry}}</td>
                    <td class="num">{{fig7_values[entry]}}</td>
                    <td class="num">{{ (fig7_values[entry] / fig7_total * 100) | round(2) }}%</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="card" style="margin-top:var(--gap);">
    <div class="card-head">
        <h3>Accounts Where The Password is The Same As The Username</h3>
        <a id="fig8_download" class="download_btn" role="button" title="Download Table" style="margin-left:auto;"
           onclick="window.location.href='{% if customer_id %}/analytics/download/fig8?customer_id={{customer_id}}{% if hashfile_id %}&hashfile_id={{hashfile_id}}{% endif %}{% elif hashfile_id %}/analytics/download/fig8?hashfile_id={{hashfile_id}}{% else %}/analytics/download/fig8{% endif %}'">{{ icon('download', size=15) }}</a>
    </div>
    <div class="card-body" style="max-height: 600px; overflow-y: auto;">
        <table class="tbl">
            <tbody>
                <tr>
                {% set pos = namespace(value=0) %}
                {% for entry in fig8_table %}
                    {% set pos.value = pos.value + 1 %}
                    <td class="mono">{{entry}}</td>
                    {% if pos.value % 3 == 0%}
                        </tr>
                        <tr>
                    {% endif %}
                {% endfor %}
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="card" style="margin-top:var(--gap);">
    <div class="card-head">
        <h3>Accounts that Share the Same Password or Password Hash</h3>
        <a id="fig9_download" class="download_btn" role="button" title="Download Table" style="margin-left:auto;"
