    </div>
    <div class="card analytics-card">
        <div class="card-head">
            <h3>Composition Makeup</h3>
            <a id="composition_makeup" class="download_btn" role="button" title="Download Chart" style="margin-left:auto;">{{ icon('download', size=15) }}</a>
        </div>
