    </div>
    <div class="card analytics-card">
        <div class="card-head">
            <h3>Recovered Hashes</h3>
            <a id="recovered_hashes" class="download_btn" role="button" title="Download Chart" style="margin-left:auto;">{{ icon('download', size=15) }}</a>
        </div>
        <div class="card-body">
