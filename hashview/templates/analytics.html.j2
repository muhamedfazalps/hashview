                plugins: [{
                    beforeDraw: function(chart,args,options){
                        const c = chart.ctx
                        c.fillStyle = '#0c0f0d';
                        c.fillRect(0, 0, chart.width, chart.height);
                    }
                }],
                options: {
                    responsive: true, //Resizes the chart canvas when its container does
                    scales: {
                        x: { ticks: { color: '#7c8a76' }, grid: { color: 'rgba(43,53,37,0.5)' } },
                        y: { beginAtZero: true, ticks: { color: '#7c8a76' }, grid: { color: 'rgba(43,53,37,0.5)' } }
                    },
                    plugins: {
                        legend: { display: false },
                        title: {
                            color: '#d2ddca',
                            display: false,
