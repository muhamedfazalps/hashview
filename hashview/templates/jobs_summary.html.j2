{% extends "layout.html.j2" %}
{% from "macros.html.j2" import icon, phos_field, status_badge, priority_pips, wizard_stepper %}
{% block title %}Job Summary · Hashview{% endblock %}
{% block content %}

<div class="page-head">
    <div>
        <h1 class="page-title">Create Job</h1>
        <div class="page-sub">// summary</div>
    </div>
</div>
{{ wizard_stepper('summary', alert_hashes=(hash_notification is not none), website=(website if website is defined else false)) }}

<form method="POST" action="">
    {{ form.hidden_tag() }}
    <div class="card">
        <div class="card-head">
            <h3>Job Summary</h3>
            <span class="page-sub" style="margin-left:8px;">// review and confirm — if everything looks good, submit below</span>
        </div>
        <div class="card-body" style="padding:0;">
            <table class="tbl">
                <tbody>
                    <tr>
                        <td style="color:var(--text-dim);width:200px;">Job Name</td>
                        <td style="font-weight:500;">{{ job.name }}</td>
                    </tr>
                    <tr>
                        <td style="color:var(--text-dim);">Customer</td>
                        <td>{{ customer.name }}</td>
                    </tr>
                    {% if settings.enabled_job_weights %}
                        <tr>
                            <td style="color:var(--text-dim);">Job Priority</td>
                            <td>
                                <span style="display:inline-flex;align-items:center;gap:8px;">
                                    {{ priority_pips(job.priority) }}
                                    {% if job.priority == 5 %}
                                        <span class="mono">{{ job.priority }} - highest</span>
                                    {% elif job.priority == 4 %}
                                        <span class="mono">{{ job.priority }} - higher</span>
                                    {% elif job.priority == 3 %}
                                        <span class="mono">{{ job.priority }} - normal</span>
                                    {% elif job.priority == 2 %}
                                        <span class="mono">{{ job.priority }} - lower</span>
                                    {% elif job.priority == 1 %}
                                        <span class="mono">{{ job.priority }} - lowest</span>
                                    {% endif %}
                                </span>
                            </td>
                        </tr>
                    {% endif %}
                    <tr>
                        <td style="color:var(--text-dim);">Hashfile</td>
                        <td>{{ hashfile.name }} <span class="mono" style="color:var(--text-mute);">({{ cracked_rate }})</span></td>
                    </tr>
                    <tr>
                        <td style="color:var(--text-dim);">Recover Amount</td>
                        {% if job.limit_recovered == 1 %}
                            <td>One and done</td>
                        {% else %}
                            <td>As much as possible</td>
                        {% endif %}
                    </tr>
                    <tr>
                        <td style="color:var(--text-dim);">Tasks</td>
                        <td>
                            {% for job_task in job_tasks %}
                                {% for task in tasks %}
                                    {% if task.id == job_task.task_id %}
                                        {{ task.name }} <br>
                                    {% endif %}
                                {% endfor %}
                            {% endfor %}
                        </td>
                    </tr>
                    <tr>
                        <td style="color:var(--text-dim);">Runtimes</td>
                        <td>
                            {% if settings.max_runtime_jobs == 0 %}
                                Job will run until completed or canceled
                            {% else %}
                                Job will run for a maximum of {{ settings.max_runtime_jobs }} hour(s).
                            {% endif %}
                            <br>
                            {% if settings.max_runtime_tasks == 0 %}
                                Tasks will run until completed or canceled
                            {% else %}
                                Each Tasks will run for a maximum of {{ settings.max_runtime_tasks }} hour(s).
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <td style="color:var(--text-dim);">Notifications</td>
                        <td>
                            {% if not job_notification and not hash_notification %}
                                <i>None</i>
                            {% endif %}
                            {% if job_notification %}
                                Job Notification: {{ job_notification.method }} <br>
                            {% endif %}
                            {% if hash_notification %}
                                Hash Notification ({{ hash_notification_cnt }} Hashes): {{ hash_notification.method }} <br>
                            {% endif %}
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="wizard-nav">
        <a class="btn" href="{{ url_for('jobs.jobs_list_tasks', job_id = job.id) }}">{{ icon('arrowLeft', size=15) }} Back</a>
        <span class="spacer"></span>
        {{ form.submit(class="btn btn-primary") }}
    </div>
</form>

{% endblock content %}
