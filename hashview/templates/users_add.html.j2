{% extends "layout.html.j2" %}
{% from "macros.html.j2" import icon, phos_field %}
{% block title %}Add User · Hashview{% endblock %}
{% block content %}

<div class="page-head">
    <div>
        <h1 class="page-title">Add User</h1>
        <div class="page-sub">// fill out the form below to provision a new user account</div>
    </div>
</div>

<form method="POST" action="">
    {{ form.hidden_tag() }}

    <div class="card">
        <div class="card-body">

            {{ phos_field(form.first_name) }}

            {{ phos_field(form.last_name) }}

            {{ phos_field(form.email) }}

            <div class="field">
                <label class="check-row" for="{{ form.is_admin.id }}">
                    {{ form.is_admin(class="hv-check") }} <span>{{ form.is_admin.label.text }}</span>
                </label>
                {% if form.is_admin.errors %}
                    <div class="invalid-feedback" style="display:block;">
                        {% for error in form.is_admin.errors %}
                            <span>{{ error }}</span>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {{ phos_field(form.password) }}

            {{ phos_field(form.confirm_password) }}

            {{ phos_field(form.pushover_app_id) }}

            {{ phos_field(form.pushover_user_key) }}

        </div>
    </div>

    <div class="wizard-nav">
        <a class="btn" href="{{ url_for('users.users_list') }}" role="button">{{ icon('arrowLeft', size=15) }} Cancel</a>
        <span class="spacer"></span>
        {{ form.submit(class="btn btn-primary") }}
    </div>
</form>

{% endblock content %}
