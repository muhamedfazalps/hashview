{% extends "layout.html.j2" %}
{% from "macros.html.j2" import phos_field %}
{% block title %}Reset Password · Hashview{% endblock %}
{% block content_anon %}
<div class="card">
    <div class="card-body">
        <div class="auth-title">Choose a New Password</div>
        <form method="POST" action="">
            {{ form.hidden_tag() }}
            {{ phos_field(form.password) }}
            {{ phos_field(form.confirm_password) }}
            {{ form.submit(class="btn btn-primary btn-block") }}
        </form>
    </div>
</div>
{% endblock %}
