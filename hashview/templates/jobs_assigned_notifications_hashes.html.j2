{% extends "layout.html.j2" %}
{% from "macros.html.j2" import icon, phos_field, status_badge, priority_pips, wizard_stepper %}
{% block title %}Create Job · Hashview{% endblock %}
{% block content %}

<div class="page-head">
    <div>
        <h1 class="page-title">Create Job</h1>
        <div class="page-sub">// alert hashes · step 4</div>
    </div>
</div>
{{ wizard_stepper('hashselect', alert_hashes=true) }}

<form method="POST" action="">
<div class="card">
    <div class="card-head">
        <div style="display:flex; align-items:center; gap:8px;">
            {{ icon('bell', size=16) }}
            <span>Hash Notifications</span>
            <span class="page-sub" style="margin:0;" title="Select the hashes you wish to be notified by once cracked. Note, cracked hash notifications will persist after job has been completed or removed.">{{ icon('info', size=14) }}</span>
        </div>
        <input type="search" id="hash_filter" class="input" placeholder="Filter hashes…" style="max-width:240px;" oninput="filterHashes(this.value)">
    </div>

    <table id="hash_options" class="tbl">
            <thead>
                <tr>
                    <th class="center" style="width:60px;"></th>
                    <th>Account</th>
                    <th>Hash</th>
                </tr>
            </thead>
            <tbody>
                {% for hash in hashes %}
                <tr>
                    <td class="center" style="vertical-align:middle;">
                        {% set has_notification = namespace(value=0) %}
                        {% for entry in existing_hash_notifications %}
                            {% if entry.hash_id |string() == hash[0] |string() %}
                                {% set has_notification.value = 1 %}
                                <input class="hv-check" type="checkbox" name='selected' value="{{hash[0]}}" checked>
                            {% endif %}
                        {% endfor %}
                        {% if has_notification.value == 0 %}
                            <input class="hv-check" type="checkbox" name='selected' value="{{hash[0]}}">
                        {% endif %}
                    </td>
                    <td style="vertical-align:middle;">
                        {% if hash[1] %}
                            {{ hash[1] | jinja_hex_decode()}}
                        {% else %}
                            <span style="color:var(--text-mute); font-style:italic;">none</span>
                        {% endif %}
                    </td>
                    <td class="mono" style="vertical-align:middle; overflow-wrap:break-word; word-break:break-word; color:var(--text-dim);">
                        {{ hash[2]}}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="wizard-nav">
        <a class="btn" href="{{ url_for('jobs.jobs_assign_notifications', job_id = job.id) }}">{{ icon('arrowLeft', size=15) }} Back</a>
        <span class="spacer"></span>
        <input type="submit" class="btn btn-primary" value="Submit">
    </div>
</form>

<script>
    function filterHashes(q){
        q = (q || '').toLowerCase();
        var rows = document.querySelectorAll('#hash_options tbody tr');
        for(var i=0; i < rows.length; i++){
            rows[i].style.display = rows[i].textContent.toLowerCase().indexOf(q) > -1 ? '' : 'none';
        }
    }
</script>
{% endblock content %}
