{% extends "layout.html.j2" %}
{% from "macros.html.j2" import icon, phos_field, status_badge, priority_pips, wizard_stepper %}
{% block content %}

<div class="page-head">
    <div>
        <h1 class="page-title">Create Job</h1>
        <div class="page-sub">// notifications · step 3</div>
    </div>
</div>
{{ wizard_stepper('notifications') }}

<form method="POST" action="">
    {{ form.hidden_tag() }}

    <div class="card">
        <div class="card-head">{{ icon('flag', size=15) }}<h3>Job completion</h3></div>
        <label class="notif-row">
            {{ icon('mail', size=19) }}
            <span class="notif-txt">
                <span class="notif-title">Email me when the job finishes</span>
                <span class="field-hint" style="margin-top:2px;">Sent to your account email when the job completes</span>
            </span>
            <span class="switch">{{ form.job_completion_email(id="job_completion_email", role="switch") }}<span class="track"></span></span>
        </label>
        <label class="notif-row" style="border-bottom:0;">
            {{ icon('bell', size=19) }}
            <span class="notif-txt">
                <span class="notif-title">Pushover alert on completion</span>
                <span class="field-hint" style="margin-top:2px;">Mobile push via your configured Pushover key</span>
            </span>
            <span class="switch">{{ form.job_completion_pushover(id="job_completion_pushover", role="switch") }}<span class="track"></span></span>
        </label>
    </div>

    <div class="card" style="margin-top:16px;">
        <div class="card-head">{{ icon('key', size=15) }}<h3>Per-hash alerts</h3></div>
        <label class="notif-row">
            {{ icon('mail', size=19) }}
            <span class="notif-txt">
                <span class="notif-title">Email on specific hash recovery</span>
                <span class="field-hint" style="margin-top:2px;">Notify the instant a flagged credential cracks (e.g. domain admin)</span>
            </span>
            <span class="switch">{{ form.hash_completion_email(id="hash_completion_email", role="switch", onchange="hvSyncAlertStep()") }}<span class="track"></span></span>
        </label>
        <label class="notif-row" style="border-bottom:0;">
            {{ icon('bell', size=19) }}
            <span class="notif-txt">
                <span class="notif-title">Pushover on specific hash recovery</span>
                <span class="field-hint" style="margin-top:2px;">Mobile push the moment a flagged hash is recovered</span>
            </span>
            <span class="switch">{{ form.hash_completion_pushover(id="hash_completion_pushover", role="switch", onchange="hvSyncAlertStep()") }}<span class="track"></span></span>
        </label>
    </div>

    <div class="field-hint" style="margin-top:14px;">↳ Per-hash targets are selected on the next step when an alert toggle is on. Cracked-hash notifications persist after the job completes or is removed.</div>

    <div class="wizard-nav">
        <a class="btn" href="{{ url_for('jobs.jobs_assigned_hashfile', job_id=job.id) }}">{{ icon('arrowLeft', size=15) }} Back</a>
        <span class="spacer"></span>
        {{ form.submit(class="btn btn-primary") }}
    </div>
</form>

<script>
    // Reveal the conditional "Alert Hashes" wizard step when a per-hash alert is on.
    function hvSyncAlertStep(){
        var a = document.getElementById('hash_completion_email');
        var b = document.getElementById('hash_completion_pushover');
        var on = (a && a.checked) || (b && b.checked);
        var s = document.querySelector('.wizard-steps');
        if (s) s.classList.toggle('show-alert', on);
    }
    document.addEventListener('DOMContentLoaded', hvSyncAlertStep);
</script>

{% endblock content %}
