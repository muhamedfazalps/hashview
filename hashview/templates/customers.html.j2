{% extends "layout.html.j2" %}
{% from "icons.html.j2" import icon %}
{% block title %}Customers · Hashview{% endblock %}
{% block content %}
<style>.customers-tbl thead th { padding-top: 14px; padding-bottom: 14px; }</style>

<div class="page-head">
    <div>
        <h1 class="page-title">Customers</h1>
        <div class="page-sub">// jobs, passwords &amp; hashes are scoped to a single customer</div>
    </div>
</div>

<div class="card">
    {% if customers %}
    <table class="tbl customers-tbl">
        <thead>
            <tr>
                <th>Name</th>
                <th class="center" style="width:160px;">Control</th>
            </tr>
        </thead>
        <tbody>
            {% for customer in customers %}
            <tr>
                <td style="font-weight:500;">{{ customer.name }}</td>
                <td class="center">
                    <div style="display:flex; gap:4px; justify-content:center;">
                        <button type="button" class="icon-btn" title="Info" onclick="document.getElementById('info-{{ customer.id }}').showModal()">{{ icon('info', size=15) }}</button>
                        <a class="icon-btn" href="/analytics?customer_id={{ customer.id }}" role="button" title="Analytics">{{ icon('chart', size=15) }}</a>
                        <button type="button" class="icon-btn act-del" title="Delete" onclick="document.getElementById('del-{{ customer.id }}').showModal()">{{ icon('trash', size=15) }}</button>
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <div class="card-body" style="text-align:center; padding:48px 24px;">
        <div class="mono" style="color:var(--text-dim);">No customers found.</div>
    </div>
    {% endif %}
</div>

{# ---- per-customer info modals (native <dialog>, no framework) ---- #}
{% for customer in customers %}
<dialog class="hv-dialog" id="info-{{ customer.id }}">
    <div class="hv-dialog-head"><h3>Info: {{ customer.name }}</h3><button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button></div>
    <div class="hv-dialog-body">
        <dl class="kv">
            <dt>Associated Jobs</dt>
            <dd>
                {% for job in jobs %}
                    {% if job.customer_id == customer.id %}
                        {{ job.name }}<br>
                    {% endif %}
                {% endfor %}
            </dd>
            <dt>Associated Hashfiles</dt>
            <dd>
                {% for hashfile in hashfiles %}
                    {% if hashfile.customer_id == customer.id %}
                        {{ hashfile.name }}<br>
                    {% endif %}
                {% endfor %}
            </dd>
        </dl>
    </div>
    <div class="hv-dialog-foot"><button class="btn" onclick="this.closest('dialog').close()">Close</button></div>
</dialog>
{% endfor %}

{# ---- per-customer delete modals ---- #}
{% for customer in customers %}
<dialog class="hv-dialog" id="del-{{ customer.id }}">
    <div class="hv-dialog-head"><h3>Delete {{ customer.name }}?</h3><button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button></div>
    <div class="hv-dialog-body">This will permanently delete the customer and any associated hashfiles and hashes. Are you sure you want to continue?</div>
    <div class="hv-dialog-foot">
        <button class="btn" onclick="this.closest('dialog').close()">Back</button>
        <form action="{{ url_for('customers.customers_delete', customer_id=customer.id) }}" method="POST" style="display:inline;">
            <input class="btn btn-danger" type="submit" value="Delete">
        </form>
    </div>
</dialog>
{% endfor %}

{% endblock content %}
