{% extends "layout.html.j2" %}
{% from "macros.html.j2" import phos_field %}
{% block title %}Reset Password · Hashview{% endblock %}
{% block content_anon %}
<div class="card">
    <div class="card-body">
        <div class="auth-title">Reset Password</div>
        <form method="POST" action="">
            {{ form.hidden_tag() }}
            {{ phos_field(form.email) }}
            {{ form.submit(class="btn btn-primary btn-block") }}
        </form>
        <div class="auth-foot">
            <a class="auth-link" href="{{ url_for('users.login_get') }}">Back to login</a>
        </div>
    </div>
</div>
{% endblock %}
