{% extends "layout.html.j2" %}
{% from "macros.html.j2" import icon, phos_field %}
{% block title %}Edit Agent · Hashview{% endblock %}
{% block content %}

<div class="page-head">
    <div>
        <h1 class="page-title">Edit Agent: {{ agent.name }}</h1>
        <div class="page-sub">// edit an agent's name</div>
    </div>
</div>

<form method="POST" action="" enctype="multipart/form-data">
    {{ agentsForm.hidden_tag() }}

    <div class="card">
        <div class="card-body">

            {{ phos_field(agentsForm.name) }}

            <input type="hidden" name="id" value={{agent.id}}>

        </div>
    </div>

    <div class="wizard-nav">
        <a class="btn" href="{{ url_for('agents.agents_list') }}" role="button">{{ icon('arrowLeft', size=15) }} Cancel</a>
        <span class="spacer"></span>
        {{ agentsForm.submit(class="btn btn-primary") }}
    </div>
</form>

{% endblock content %}
