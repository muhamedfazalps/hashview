<style>
    /* dependency-free carousel: native horizontal scroll-snap + JS arrows/dots */
    .wrap-carousel { position: relative; }
    .wrap-track {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        scrollbar-width: none;
    }
    .wrap-track::-webkit-scrollbar { display: none; }
    .wrap-slide { flex: 0 0 100%; scroll-snap-align: start; min-width: 0; padding: 2px; }
    .wrap-nav { display: flex; justify-content: center; align-items: center; gap: 16px; margin-top: 18px; }
    .wrap-dots { display: flex; gap: 7px; }
    .wrap-dot {
        width: 8px; height: 8px; border-radius: 50%; padding: 0;
        background: var(--surface-3); border: 1px solid var(--border-bright); cursor: pointer;
        transition: background .15s, border-color .15s;
    }
    .wrap-dot.active { background: var(--primary); border-color: var(--primary); box-shadow: var(--glow-sm); }
</style>
<script src="{{ url_for('static', filename='js/confetti.bundle.min.js') }}"></script>
<script type="text/javascript">
    window.onload = function() {
        const duration = 15 * 1000,
        animationEnd = Date.now() + duration,
        defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 0 };

        function randomInRange(min, max) {
        return Math.random() * (max - min) + min;
        }

        const interval = setInterval(function() {
        const timeLeft = animationEnd - Date.now();

        if (timeLeft <= 0) {
            return clearInterval(interval);
        }

        const particleCount = 50 * (timeLeft / duration);

        // since particles fall down, start a bit higher than random
        confetti(
            Object.assign({}, defaults, {
            particleCount,
            origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 },
            })
        );
        confetti(
            Object.assign({}, defaults, {
            particleCount,
            origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 },
            })
        );
        }, 250);
};
</script>
