<script>
(function () {
    var track = document.getElementById('wrapTrack');
    var dotsWrap = document.getElementById('wrapDots');
    if (!track) return;
    var count = track.children.length;
    var idx = 0;

    for (var i = 0; i < count; i++) {
        var d = document.createElement('button');
        d.type = 'button';
        d.className = 'wrap-dot' + (i === 0 ? ' active' : '');
        d.setAttribute('aria-label', 'Slide ' + (i + 1));
        (function (n) { d.addEventListener('click', function () { wrapGo(n); }); })(i);
        dotsWrap.appendChild(d);
    }
    function syncDots() {
        var dots = dotsWrap.children;
        for (var i = 0; i < dots.length; i++) { dots[i].classList.toggle('active', i === idx); }
    }
    function clamp(n) { return Math.max(0, Math.min(count - 1, n)); }
    window.wrapGo = function (n) {
        idx = clamp(n);
        track.scrollTo({ left: idx * track.clientWidth, behavior: 'smooth' });
        syncDots();
    };
    window.wrapMove = function (delta) { wrapGo(idx + delta); };

    var t;
    track.addEventListener('scroll', function () {
        clearTimeout(t);
        t = setTimeout(function () { idx = clamp(Math.round(track.scrollLeft / track.clientWidth)); syncDots(); }, 90);
    });
})();
</script>
