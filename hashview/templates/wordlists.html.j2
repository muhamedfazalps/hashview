{% extends "layout.html.j2" %}
{% block header %}
<br>
<br>
<br>
<br>
<br>
{% endblock header %}
{% block content %}
    <article class="media content-section">
        <div class="media-body">
            <div class="card">
                <h4 class="card-header">
                    Static Wordlists
                    <i class="fa fa-question-circle fa-sm" data-toggle="tooltip" title="These are plaintext, newline delimited files that you can upload to hashview and then assign to a task." style="margin-left:5px;"></i>
                    <a class="btn btn-success btn-sm mt-1 mb-1 pull-right" href="{{ url_for('wordlists.wordlists_add') }}">Add</a>
                </h4>
                <div class="card-body ">              
                    <table class="table">
                        <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Size</th>
                            <th scope="col">Owner</th>
                            <th scope="col">Last Updated</th>
                            <th style="width:110px" scope="col">Control</th> 
                        </tr>
                        </thead>
                        <tbody>
                            {% for wordlist in static_wordlists %}
                                <tr>
                                    <td style="vertical-align:middle;">{{ wordlist.name }}</td>
                                    <td style="vertical-align:middle;">{{ wordlist.size }}</td>
                                    <td style="vertical-align:middle;">
                                        {% for user in users %}
                                            {% if user.id == wordlist.owner_id %}
                                                {{ user.first_name }} {{ user.last_name }}
                                            {% endif %}
                                        {% endfor %}
                                    </td>
                                    <td style="vertical-align:middle;">{{ wordlist.last_updated }}</td>
                                    <td style="vertical-align:middle;">
                                        <button type="button" class="fa fa-info btn btn-info" data-bs-toggle="modal" data-bs-target="#infoModal{{wordlist.id}}" title=Info></button>
                                        <button type="button" class="fa fa-trash btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal{{wordlist.id}}" title=Delete></button>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            <br>
            <div class="card">
                <h4 class="card-header">
                    Dynamic Wordlists 
                    <i class="fa fa-question-circle fa-sm" data-toggle="tooltip" title="The Dynamic Wordlist are automatically generated for you. They will update anytime new data is added to the system." style="margin-left:5px;"></i>
                </h4>
                <div class="card-body "> 
                    <table class="table">
                        <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Size</th>
                            <th scope="col">Last Updated</th>
                            <th style="width:110px" scope="col">Control</th> 
                        </tr>
                        </thead>
                        <tbody>
                            {% for wordlist in dynamic_wordlists %}
                                <tr>
                                    <td style="vertical-align:middle;">{{ wordlist.name }}</td>
                                    <td style="vertical-align:middle;">{{ wordlist.size }}</td>
                                    <td style="vertical-align:middle;">{{ wordlist.last_updated }}</td>
                                    <td style="vertical-align:middle;">
                                        <button type="button" class="fa fa-info btn btn-info" data-bs-toggle="modal" data-bs-target="#infoModal{{wordlist.id}}" title=Info></button>
                                        <a class="fa fa-undo btn btn-warning" href="/wordlists/update/{{wordlist.id}}" role="button" title=Update></a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </article>
    {% for wordlist in wordlists %}
    <!-- Info Modal -->
    <div class="modal fade" id="infoModal{{wordlist.id}}" tabindex="-1" aria-labelledby="infoModal{{wordlist.id}}Label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header d-flex align-items-center">
                <h5 class="modal-title" id="infoModal{{wordlist.id}}Label">Info: {{wordlist.name}}</h5>
                <button type="button" class="btn btn-secondary ms-auto" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
            The following tasks are using this wordlist.<br>
            <br>
                {% for task in tasks %}
                    {% if task.wl_id == wordlist.id %}
                        {{task.name}} <br>
                    {% endif %}
                {% endfor %}
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
        </div>
    </div>
    {% endfor %}
    {% for wordlist in wordlists %}
    <!-- DeleteModal -->
    <div class="modal fade" id="deleteModal{{wordlist.id}}" tabindex="-1" aria-labelledby="deleteModal{{wordlist.id}}Label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header d-flex align-items-center">
                <h5 class="modal-title" id="deleteModal{{wordlist.id}}Label">Delete: {{wordlist.name}} ?</h5>
                <button type="button" class="btn btn-secondary ms-auto" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                This will permanantly delete the account. Are you sure you want to continue?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <form action="{{ url_for('wordlists.wordlists_delete', wordlist_id=wordlist.id) }}" method="POST">
                    <input class="btn btn-danger" type="submit" value="Delete">
                </form>
            </div>
        </div>
        </div>
    </div>
    {% endfor %}
{% endblock content %}
