{% extends "layout.html.j2" %}
{% from "icons.html.j2" import icon %}
{% block title %}Wordlists · Hashview{% endblock %}
{% block content %}
{% macro wcount(n) -%}
{%- if n and n >= 1000000 -%}{{ (n / 1000000)|round(1) }}M{%- elif n and n >= 1000 -%}{{ (n / 1000)|round(1) }}K{%- else -%}{{ n or 0 }}{%- endif -%}
{%- endmacro %}
{% macro kv_label(t) -%}<div class="mono" style="font-size:9.5px; letter-spacing:1px; text-transform:uppercase; color:var(--text-mute); margin-bottom:6px;">{{ t }}</div>{%- endmacro %}

<div class="page-head">
    <div>
        <h1 class="page-title">Wordlists</h1>
        <div class="page-sub">// plaintext &amp; auto-generated wordlists</div>
    </div>
    <button type="button" class="btn btn-primary" onclick="document.getElementById('upload-wordlist-modal').showModal()">{{ icon('upload', size=15) }} Upload Wordlist</button>
</div>

<div class="card">
    <div class="card-head">
        <h3>Static Wordlists</h3>
        <span class="field-hint" style="margin-top:0;">Plaintext, newline-delimited files you upload and assign to a task.</span>
        <span style="margin-left:auto; display:inline-flex; align-items:center; gap:9px; color:var(--text-mute);">{{ icon('search', size=16) }}<input type="text" id="wl-filter" class="input" style="width:240px; flex:none;" placeholder="filter wordlists…" autocomplete="off" oninput="hvFilterWordlists(this.value)"></span>
    </div>
    {% if static_wordlists %}
    <table class="tbl" style="table-layout:fixed;">
        <colgroup><col style="width:32%;"><col style="width:14%;"><col style="width:18%;"><col style="width:20%;"><col style="width:16%;"></colgroup>
        <thead>
            <tr>
                <th>Name</th>
                <th>Size</th>
                <th>Owner</th>
                <th>Last Updated</th>
                <th class="center">Control</th>
            </tr>
        </thead>
        <tbody id="wl-static-tbody">
            {% for wordlist in static_wordlists %}
            <tr data-name="{{ wordlist.name|lower }}">
                <td style="font-weight:500;">
                    <span style="display:inline-flex; align-items:center; gap:9px;">
                        <span style="color:var(--text-mute); display:inline-flex;">{{ icon('book', size=16) }}</span>
                        {{ wordlist.name }}
                    </span>
                </td>
                <td class="mono num" style="color:var(--primary);">{{ "{:,}".format(wordlist.size) }}</td>
                <td style="color:var(--text-dim);">
                    {% for user in users %}
                        {% if user.id == wordlist.owner_id %}
                            {{ user.first_name }} {{ user.last_name }}
                        {% endif %}
                    {% endfor %}
                </td>
                <td class="mono" style="color:var(--text-mute);font-size:11.5px;">{{ wordlist.last_updated }}</td>
                <td class="center">
                    <div style="display:flex; gap:4px; justify-content:center;">
                        <button type="button" class="icon-btn" title="Info" onclick="document.getElementById('info-{{ wordlist.id }}').showModal()">{{ icon('info', size=15) }}</button>
                        <button type="button" class="icon-btn act-del" title="Delete" onclick="document.getElementById('del-{{ wordlist.id }}').showModal()">{{ icon('trash', size=15) }}</button>
                    </div>
                </td>
            </tr>
            {% endfor %}
            <tr class="wl-no-match" style="display:none;"><td colspan="5" style="text-align:center; padding:24px 16px; color:var(--text-mute);" class="mono">No wordlists match that filter.</td></tr>
        </tbody>
    </table>
    {% else %}
    <div class="card-body" style="text-align:center; padding:48px 24px;">
        <div class="mono" style="color:var(--text-dim); margin-bottom:14px;">No static wordlists found.</div>
        <button type="button" class="btn btn-primary" onclick="document.getElementById('upload-wordlist-modal').showModal()">{{ icon('upload', size=15) }} Upload Wordlist</button>
    </div>
    {% endif %}
</div>

<div class="card" style="margin-top:var(--gap);">
    <div class="card-head">
        <h3>Dynamic Wordlists</h3>
        <span class="field-hint" style="margin-top:0;">Auto-generated and updated whenever new data is added to the system.</span>
    </div>
    {% if dynamic_wordlists %}
    <table class="tbl" style="table-layout:fixed;">
        <colgroup><col style="width:32%;"><col style="width:14%;"><col style="width:18%;"><col style="width:20%;"><col style="width:16%;"></colgroup>
        <thead>
            <tr>
                <th>Name</th>
                <th>Size</th>
                <th></th>
                <th>Last Updated</th>
                <th class="center">Control</th>
            </tr>
        </thead>
        <tbody id="wl-dynamic-tbody">
            {% for wordlist in dynamic_wordlists %}
            <tr data-name="{{ wordlist.name|lower }}">
                <td style="font-weight:500;">
                    <span style="display:inline-flex; align-items:center; gap:9px;">
                        <span style="color:var(--text-mute); display:inline-flex;">{{ icon('book', size=16) }}</span>
                        {{ wordlist.name }}
                    </span>
                </td>
                <td class="mono num" style="color:var(--primary);">{{ "{:,}".format(wordlist.size) }}</td>
                <td></td>
                <td class="mono" style="color:var(--text-mute);font-size:11.5px;">{{ wordlist.last_updated }}</td>
                <td class="center">
                    <div style="display:flex; gap:4px; justify-content:center;">
                        <button type="button" class="icon-btn" title="Info" onclick="document.getElementById('info-{{ wordlist.id }}').showModal()">{{ icon('info', size=15) }}</button>
                        <a class="icon-btn" href="/wordlists/update/{{ wordlist.id }}" role="button" title="Update">{{ icon('refresh', size=15) }}</a>
                    </div>
                </td>
            </tr>
            {% endfor %}
            <tr class="wl-no-match" style="display:none;"><td colspan="5" style="text-align:center; padding:24px 16px; color:var(--text-mute);" class="mono">No wordlists match that filter.</td></tr>
        </tbody>
    </table>
    {% else %}
    <div class="card-body" style="text-align:center; padding:48px 24px;">
        <div class="mono" style="color:var(--text-dim);">No dynamic wordlists found.</div>
    </div>
    {% endif %}
</div>

{# ---- upload-wordlist modal (opened from the "Upload Wordlist" button) ---- #}
<style>
/* inset the whole progress block from the modal edges so the step list (left)
   and the percentage (right) sit centered with breathing room, while each row
   stays left/right justified */
#upload-wordlist-modal #wl-progress { padding: 10px 30px 4px; }
#upload-wordlist-modal .wl-steps { display:flex; flex-direction:column; gap:13px; margin:4px 0 20px; }
#upload-wordlist-modal .wl-step { display:flex; align-items:center; gap:11px; color:var(--text-mute); transition:color .2s; }
#upload-wordlist-modal .wl-step-dot { width:18px; height:18px; flex:none; border-radius:50%; border:2px solid var(--border); position:relative; transition:all .2s; }
#upload-wordlist-modal .wl-step-name { font-size:13px; }
#upload-wordlist-modal .wl-step-meta { margin-left:auto; font-size:11.5px; color:var(--text-mute); }
#upload-wordlist-modal .wl-step.active { color:var(--text); }
#upload-wordlist-modal .wl-step.active .wl-step-dot { border-color:var(--primary); box-shadow:var(--glow-sm); }
#upload-wordlist-modal .wl-step.active .wl-step-dot::after { content:""; position:absolute; inset:3px; border-radius:50%; background:var(--primary); animation:wlPulse 1s ease-in-out infinite; }
#upload-wordlist-modal .wl-step.done { color:var(--text); }
#upload-wordlist-modal .wl-step.done .wl-step-dot { border-color:var(--primary); background:var(--primary); }
#upload-wordlist-modal .wl-step.done .wl-step-dot::after { content:"✓"; position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-size:11px; line-height:1; color:var(--bg); font-weight:700; }
@keyframes wlPulse { 0%,100%{opacity:1;} 50%{opacity:.3;} }
#upload-wordlist-modal .wl-bar { height:6px; border-radius:3px; background:var(--surface-3); overflow:hidden; }
#upload-wordlist-modal .wl-bar-fill { height:100%; width:0%; border-radius:3px; background:linear-gradient(90deg,var(--primary-deep),var(--primary)); box-shadow:var(--glow-sm); transition:width .15s ease; }
#upload-wordlist-modal .wl-bar.indeterminate .wl-bar-fill { width:38% !important; transition:none; animation:wlIndet 1.1s ease-in-out infinite; }
@keyframes wlIndet { 0%{margin-left:-38%;} 100%{margin-left:100%;} }
</style>
<dialog class="hv-dialog" id="upload-wordlist-modal" style="max-width:560px; width:92vw;" oncancel="hvWlOnCancel(event)">
    <div class="hv-dialog-head">
        {{ icon('book', size=16) }}
        <div style="line-height:1.2;">
            <h3 style="margin:0;">Upload Wordlist</h3>
            <div class="mono" style="font-size:10px; letter-spacing:0.5px; text-transform:uppercase; color:var(--text-mute); margin-top:3px;">plaintext or .gz, newline-delimited</div>
        </div>
        <button type="button" class="icon-btn" id="wl-up-close" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button>
    </div>
    <form id="wl-upload-form" method="POST" action="{{ url_for('wordlists.wordlists_add') }}" enctype="multipart/form-data" onsubmit="return hvWlSubmit(event)">
        {{ wordlistsForm.hidden_tag() }}
        {{ wordlistsForm.name(id="wl-up-name", style="display:none;") }}
        <div class="hv-dialog-body">
            {# ----- file-pick state ----- #}
            <div id="wl-pick">
                <div class="dropzone" id="wl-dropzone" onclick="document.getElementById('wl-up-file').click()"
                     ondragover="event.preventDefault(); this.classList.add('drag');"
                     ondragleave="this.classList.remove('drag');"
                     ondrop="hvWlDrop(event)">
                    {{ icon('upload', size=34) }}
                    <div style="margin-top:12px; color:var(--text);">Drop a wordlist file here or <span style="color:var(--primary); text-decoration:underline;">browse</span></div>
                    <div class="field-hint mono" id="wl-dropzone-name" style="margin-top:8px;">rockyou.txt, weakpass.txt, … plaintext or a .gz</div>
                    {{ wordlistsForm.wordlist(id="wl-up-file", style="display:none;", onchange="hvWlChosen(this)") }}
                </div>
                {% if wordlistsForm.wordlist.errors %}<div class="invalid-feedback" style="display:block;">{% for e in wordlistsForm.wordlist.errors %}<span>{{ e }}</span>{% endfor %}</div>{% endif %}
                <div class="invalid-feedback" id="wl-pick-error" style="display:none;"></div>
            </div>

            {# ----- progress state (shown while the file uploads + server compresses) ----- #}
            <div id="wl-progress" style="display:none;">
                <div class="wl-steps">
                    <div class="wl-step" id="wl-step-upload">
                        <span class="wl-step-dot"></span>
                        <span class="wl-step-name">Uploading file</span>
                        <span class="wl-step-meta mono" id="wl-step-upload-meta"></span>
                    </div>
                    <div class="wl-step" id="wl-step-receive">
                        <span class="wl-step-dot"></span>
                        <span class="wl-step-name">Receiving on server</span>
                        <span class="wl-step-meta mono" id="wl-step-receive-meta"></span>
                    </div>
                    <div class="wl-step" id="wl-step-compress">
                        <span class="wl-step-dot"></span>
                        <span class="wl-step-name">Compressing &amp; indexing</span>
                        <span class="wl-step-meta mono" id="wl-step-compress-meta"></span>
                    </div>
                    <div class="wl-step" id="wl-step-done">
                        <span class="wl-step-dot"></span>
                        <span class="wl-step-name">Done</span>
                        <span class="wl-step-meta mono" id="wl-step-done-meta"></span>
                    </div>
                </div>
                <div class="wl-bar" id="wl-bar"><div class="wl-bar-fill" id="wl-bar-fill"></div></div>
                <div class="mono" id="wl-status-text" style="margin-top:11px; font-size:12px; color:var(--text-dim);">Preparing…</div>
                <div class="invalid-feedback" id="wl-progress-error" style="display:none; margin-top:11px;"></div>
            </div>
        </div>
        <div class="hv-dialog-foot">
            <button type="button" class="btn" id="wl-up-cancel" onclick="hvWlCancel()">Cancel</button>
            <button type="submit" class="btn btn-primary" id="wl-up-submit">{{ icon('upload', size=15) }} Upload Wordlist</button>
        </div>
    </form>
</dialog>
<script>
    var hvWlXhr = null;       // in-flight upload request
    var hvWlBusy = false;     // true while uploading/compressing

    function hvWlChosen(input){
        var n = (input.files && input.files.length) ? input.files[0].name : '';
        var hint = document.getElementById('wl-dropzone-name');
        if (hint) hint.textContent = n ? ('Selected: ' + n) : 'rockyou.txt, weakpass.txt, … plaintext or a .gz';
        var nameEl = document.getElementById('wl-up-name');
        if (nameEl && n) nameEl.value = n;
        var err = document.getElementById('wl-pick-error');
        if (err) err.style.display = 'none';
    }
    function hvWlDrop(e){
        e.preventDefault();
        var dz = document.getElementById('wl-dropzone');
        if (dz) dz.classList.remove('drag');
        var input = document.getElementById('wl-up-file');
        if (input && e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files.length){
            input.files = e.dataTransfer.files;
            hvWlChosen(input);
        }
    }

    // ordered phases of the status stepper; hvWlPhase marks everything before
    // the named phase "done", the named one "active" (or "done" at the end)
    var HVWL_PHASES = ['upload', 'receive', 'compress', 'done'];
    function hvWlPhase(name){
        var idx = HVWL_PHASES.indexOf(name);
        HVWL_PHASES.forEach(function(s, i){
            var el = document.getElementById('wl-step-' + s);
            if (!el) return;
            el.classList.remove('active', 'done');
            if (name === 'done' || i < idx) el.classList.add('done');
            else if (i === idx) el.classList.add('active');
        });
    }

    function hvWlSubmit(e){
        e.preventDefault();
        var form = document.getElementById('wl-upload-form');
        var fileInput = document.getElementById('wl-up-file');
        if (!fileInput.files || !fileInput.files.length){
            var pe = document.getElementById('wl-pick-error');
            pe.textContent = 'Please choose a wordlist file first.';
            pe.style.display = 'block';
            return false;
        }
        var nameEl = document.getElementById('wl-up-name');
        if (nameEl && !nameEl.value) nameEl.value = fileInput.files[0].name;

        // switch to the progress view
        document.getElementById('wl-pick').style.display = 'none';
        document.getElementById('wl-progress').style.display = 'block';
        document.getElementById('wl-up-submit').style.display = 'none';
        document.getElementById('wl-up-close').style.display = 'none';
        document.getElementById('wl-progress-error').style.display = 'none';
        hvWlBusy = true;
        var bar = document.getElementById('wl-bar');
        var statusEl = document.getElementById('wl-status-text');
        var phase = 'upload';   // local guard so phases only move forward
        HVWL_PHASES.forEach(function(s){
            var m = document.getElementById('wl-step-' + s + '-meta'); if (m) m.textContent = '';
        });
        hvWlPhase('upload');
        bar.classList.remove('indeterminate');
        document.getElementById('wl-bar-fill').style.width = '0%';
        statusEl.textContent = 'Uploading…';

        var xhr = new XMLHttpRequest();
        hvWlXhr = xhr;
        xhr.open('POST', form.action, true);
        xhr.setRequestHeader('X-Requested-With', 'fetch');

        xhr.upload.onprogress = function(ev){
            if (!ev.lengthComputable) return;
            var pct = Math.round(ev.loaded / ev.total * 100);
            if (phase === 'upload'){
                document.getElementById('wl-bar-fill').style.width = pct + '%';
                document.getElementById('wl-step-upload-meta').textContent = pct + '%';
                statusEl.textContent = 'Uploading… ' + pct + '%';
            }
            // The instant every byte has been sent, leave the "Uploading" step.
            // For a large file the server then spends time reading the body off
            // the socket before it can start compressing; without this the UI
            // would sit at "Uploading… 100%" and look hung.
            if (pct >= 100 && phase === 'upload'){
                phase = 'receive';
                document.getElementById('wl-step-upload-meta').textContent = '100%';
                hvWlPhase('receive');
                bar.classList.add('indeterminate');
                statusEl.textContent = 'Transfer complete — receiving on the server…';
            }
        };
        xhr.upload.onload = function(){
            // body fully received by the server; it's now compressing/indexing
            if (phase === 'upload' || phase === 'receive'){
                phase = 'compress';
                document.getElementById('wl-step-upload-meta').textContent = '100%';
                document.getElementById('wl-bar-fill').style.width = '100%';
                hvWlPhase('compress');
                bar.classList.add('indeterminate');
                statusEl.textContent = 'Compressing & indexing on the server (large files can take a while)…';
            }
        };
        xhr.onload = function(){
            hvWlXhr = null; hvWlBusy = false;
            bar.classList.remove('indeterminate');
            var data = {};
            try { data = JSON.parse(xhr.responseText); } catch (err) {}
            if (xhr.status >= 200 && xhr.status < 300 && data && data.status === 'ok'){
                phase = 'done';
                hvWlPhase('done');
                document.getElementById('wl-bar-fill').style.width = '100%';
                statusEl.textContent = data.msg || 'Done.';
                setTimeout(function(){ window.location = data.redirect || window.location.href; }, 800);
            } else {
                hvWlFail((data && data.msg) ? data.msg : ('Upload failed (HTTP ' + xhr.status + ').'));
            }
        };
        xhr.onerror = function(){ hvWlXhr = null; hvWlBusy = false; hvWlFail('Network error during upload.'); };
        xhr.onabort  = function(){ hvWlXhr = null; hvWlBusy = false; };
        xhr.send(new FormData(form));
        return false;
    }

    function hvWlFail(msg){
        document.getElementById('wl-bar').classList.remove('indeterminate');
        // return to the file-pick view so the user can retry or close
        document.getElementById('wl-progress').style.display = 'none';
        document.getElementById('wl-pick').style.display = 'block';
        document.getElementById('wl-up-submit').style.display = '';
        document.getElementById('wl-up-close').style.display = '';
        var err = document.getElementById('wl-pick-error');
        err.textContent = msg;
        err.style.display = 'block';
    }

    function hvWlReset(){
        if (hvWlXhr){ try { hvWlXhr.abort(); } catch (e) {} hvWlXhr = null; }
        hvWlBusy = false;
        document.getElementById('wl-pick').style.display = 'block';
        document.getElementById('wl-progress').style.display = 'none';
        document.getElementById('wl-up-submit').style.display = '';
        document.getElementById('wl-up-close').style.display = '';
        document.getElementById('wl-progress-error').style.display = 'none';
        var pe = document.getElementById('wl-pick-error'); if (pe) pe.style.display = 'none';
        HVWL_PHASES.forEach(function(s){
            var el = document.getElementById('wl-step-' + s);
            if (el) el.classList.remove('active', 'done');
            var m = document.getElementById('wl-step-' + s + '-meta'); if (m) m.textContent = '';
        });
        document.getElementById('wl-bar').classList.remove('indeterminate');
        document.getElementById('wl-bar-fill').style.width = '0%';
        var f = document.getElementById('wl-up-file'); if (f) f.value = '';
        var n = document.getElementById('wl-up-name'); if (n) n.value = '';
        var hint = document.getElementById('wl-dropzone-name');
        if (hint) hint.textContent = 'rockyou.txt, weakpass.txt, … plaintext or a .gz';
    }

    function hvWlCancel(){
        // aborts an in-flight upload (if any), resets, and closes the modal
        hvWlReset();
        document.getElementById('upload-wordlist-modal').close();
    }

    function hvWlOnCancel(e){
        // block the Esc key from dismissing the dialog mid-upload
        if (hvWlBusy) e.preventDefault();
    }
</script>

{# ---- per-wordlist modals (native <dialog>, no framework) ---- #}
{% for wordlist in wordlists %}
<dialog class="hv-dialog" id="info-{{ wordlist.id }}" style="max-width:720px; width:95vw;">
    {% set used = wl_used_tasks.get(wordlist.id, []) if wl_used_tasks is defined else [] %}
    {% set hits = wl_hits.get(wordlist.id, 0) if wl_hits is defined else 0 %}
    {% set tcount = wl_task_count.get(wordlist.id, 0) if wl_task_count is defined else 0 %}
    {% set jcount = wl_job_count.get(wordlist.id, 0) if wl_job_count is defined else 0 %}
    {# on-disk size of the stored file (compressed .gz for static wordlists) #}
    {% set size_on_disk = (wordlist.byte_size | filesizeformat) if wordlist.byte_size else '—' %}
    <div class="hv-dialog-head">
        {{ icon('info', size=16) }}
        <div style="line-height:1.2;">
            <h3 style="margin:0;">{{ wordlist.name }}</h3>
            <div class="mono" style="font-size:10px; letter-spacing:0.5px; color:var(--text-mute); margin-top:3px;">wordlist details</div>
        </div>
        <button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button>
    </div>
    <div class="hv-dialog-body" style="max-height:74vh; overflow-y:auto;">
        {# summary strip #}
        <div style="display:flex; align-items:center; gap:14px; margin-bottom:22px;">
            <span style="flex:none; width:46px; height:46px; border-radius:11px; display:inline-flex; align-items:center; justify-content:center; color:var(--primary); border:1px solid var(--primary-dim); background:rgba(var(--primary-rgb),0.08);">{{ icon('book', size=20) }}</span>
            <div style="line-height:1.4;">
                <span class="mono" style="font-size:22px; color:var(--text);">{{ wcount(wordlist.size) }}<span style="font-size:12px; color:var(--text-mute);"> words</span></span>
                <div class="mono" style="font-size:11px; color:var(--text-mute); margin-top:3px;">{{ size_on_disk }} on disk · uploaded {{ wordlist.last_updated.strftime('%Y-%m-%d') if wordlist.last_updated else '—' }}</div>
            </div>
            <span style="margin-left:auto; text-align:right; line-height:1;">
                <span class="mono" style="font-size:22px; color:var(--primary); text-shadow:var(--glow-text);">{{ "{:,}".format(hits|int) }}</span>
                <span class="mono" style="display:block; font-size:9px; letter-spacing:1px; color:var(--text-mute); margin-top:3px;">HITS</span>
            </span>
        </div>

        {# detail grid #}
        <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 18px 24px;">
            <div>{{ kv_label('Owner') }}<div><span class="badge dim">{{ wl_owner.get(wordlist.id, '—') if wl_owner is defined else '—' }}</span></div></div>
            <div>{{ kv_label('Uploaded') }}<div class="mono" style="color:var(--text);">{{ wordlist.last_updated.strftime('%Y-%m-%d') if wordlist.last_updated else '—' }}</div></div>
            <div>{{ kv_label('Words') }}<div class="mono" style="color:var(--text);">{{ "{:,}".format(wordlist.size|int) }}</div></div>
            <div>{{ kv_label('Size on disk') }}<div class="mono" style="color:var(--text);">{{ size_on_disk }}</div></div>
            <div>{{ kv_label('Historical hits') }}<div><span class="mono" style="color:{{ 'var(--primary)' if hits else 'var(--text-mute)' }};{% if hits %}text-shadow:var(--glow-text);{% endif %}">{{ "{:,}".format(hits|int) }}</span> <span style="color:var(--text-dim);">passwords recovered</span></div></div>
            <div>{{ kv_label('Used by') }}<div style="color:var(--text);">{{ tcount }} task{{ '' if tcount == 1 else 's' }} · {{ jcount }} job{{ '' if jcount == 1 else 's' }}</div></div>
        </div>

        {# used-by tasks #}
        <div style="margin-top:24px;">
            <div class="mono" style="display:flex; align-items:center; gap:8px; font-size:10px; letter-spacing:1px; text-transform:uppercase; color:var(--text-mute); margin-bottom:11px;">{{ icon('task', size=14) }} Used by {{ used|length }} task{{ '' if used|length == 1 else 's' }}</div>
            {% if used %}
            {% for u in used %}
            <div class="card" style="margin-bottom:8px; padding:11px 14px; display:flex; align-items:center; gap:10px;">
                <span style="color:var(--text-mute); display:inline-flex;">{{ icon('task', size=15) }}</span>
                <span style="font-weight:500; color:var(--text); min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="{{ u.name }}">{{ u.name }}</span>
                <span style="margin-left:auto; display:inline-flex; align-items:center; gap:10px; flex:none;">
                    {% if u.rule %}<span class="mono" style="color:var(--cyan); font-size:11px;">{{ u.rule }}</span>{% endif %}
                    <span class="badge dim" style="font-size:8.5px;">{{ u.type }}</span>
                    <span class="mono" style="color:{{ 'var(--primary)' if u.hits else 'var(--text-mute)' }}; white-space:nowrap;">{{ "{:,}".format(u.hits|int) }} hits</span>
                </span>
            </div>
            {% endfor %}
            {% else %}
            <div class="mono" style="color:var(--text-mute);">Not used by any tasks yet.</div>
            {% endif %}
        </div>
    </div>
    <div class="hv-dialog-foot">
        <span class="mono" style="margin-right:auto; font-size:11.5px; color:var(--text-mute);">{{ "{:,}".format(wordlist.size|int) }} words · {{ size_on_disk }}</span>
        <button class="btn" onclick="this.closest('dialog').close()">Close</button>
    </div>
</dialog>
{% endfor %}

{% for wordlist in wordlists %}
<dialog class="hv-dialog" id="del-{{ wordlist.id }}">
    <div class="hv-dialog-head"><h3>Delete {{ wordlist.name }}?</h3><button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button></div>
    <div class="hv-dialog-body">This will permanently delete the wordlist. Are you sure you want to continue?</div>
    <div class="hv-dialog-foot">
        <button class="btn" onclick="this.closest('dialog').close()">Back</button>
        <form action="{{ url_for('wordlists.wordlists_delete', wordlist_id=wordlist.id) }}" method="POST" style="display:inline;">
            <input class="btn btn-danger" type="submit" value="Delete">
        </form>
    </div>
</dialog>
{% endfor %}

<script>
function hvFilterWordlists(q){
    q = (q || '').trim().toLowerCase();
    ['wl-static-tbody', 'wl-dynamic-tbody'].forEach(function(tid){
        var tb = document.getElementById(tid);
        if (!tb) return;
        var shown = 0;
        tb.querySelectorAll('tr[data-name]').forEach(function(tr){
            var hit = !q || (tr.getAttribute('data-name') || '').indexOf(q) !== -1;
            tr.style.display = hit ? '' : 'none';
            if (hit) shown++;
        });
        var none = tb.querySelector('.wl-no-match');
        if (none) none.style.display = shown === 0 ? '' : 'none';
    });
}
</script>

{% endblock content %}
