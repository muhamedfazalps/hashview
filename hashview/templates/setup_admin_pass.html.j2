{% extends "setup_base.html.j2" %}
{% from "macros.html.j2" import phos_field with context %}

{% block setup_title %}Edit Admin User{% endblock %}

{% block content %}
<form method="POST" action="/setup/admin-pass">
    {{ form.hidden_tag() }}
    {{ phos_field(form.first_name) }}
    {{ phos_field(form.last_name) }}
    {{ phos_field(form.email_address) }}
    {{ phos_field(form.password) }}
    {{ phos_field(form.confirm_password) }}
    {{ form.submit(class="btn btn-primary btn-block") }}
</form>
{% endblock %}
