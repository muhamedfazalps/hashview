{# ============================================================
   Phosphor Console macros (Bootstrap-free).
   ============================================================ #}
{% from "icons.html.j2" import icon %}

{# Render a WTForms field with the phosphor .field/.input styling,
   preserving the is-invalid / invalid-feedback error contract. #}
{% macro phos_field(field, placeholder='') -%}
<div class="field">
  <label class="field-label"{% if field.id %} for="{{ field.id }}"{% endif %}>{{ field.label.text }}{% if field.flags.required %} <span class="req">*</span>{% endif %}</label>
  {% if field.errors %}
    {{ field(class="input is-invalid", placeholder=placeholder) }}
    <div class="invalid-feedback">
      {% for error in field.errors %}<span>{{ error }}</span>{% endfor %}
    </div>
  {% else %}
    {{ field(class="input", placeholder=placeholder) }}
  {% endif %}
</div>
{%- endmacro %}

{# Status pill — ported from ui.jsx StatusBadge. Tone + optional icon + label. #}
{% macro status_badge(status) -%}
{%- set m = {
  'Running':   ['amber', 'refresh', 'RUNNING'],
  'Completed': ['green', 'check',   'COMPLETE'],
  'Queued':    ['dim',   'clock',   'QUEUED'],
  'Ready':     ['dim',   'clock',   'READY'],
  'Canceled':  ['red',   'ban',     'CANCELED'],
  'Paused':    ['dim',   'clock',   'PAUSED'],
  'Importing': ['cyan',  'refresh', 'IMPORTING'],
  'online':    ['green', '',        'ONLINE'],
  'offline':   ['red',   '',        'OFFLINE'],
  'running':   ['amber', '',        'CRACKING']
} -%}
{%- set spec = m.get(status, ['dim', '', status|upper]) -%}
<span class="badge {{ spec[0] }}">
  {%- if spec[1] %}{{ icon(spec[1], cls='ico' + (' spin' if status == 'Running' else ''), size=13) }}{% endif -%}
  {{ spec[2] }}
</span>
{%- endmacro %}

{# Priority pips 1..5 — ported from ui.jsx PriorityPips. #}
{% macro priority_pips(n) -%}
<span style="display:inline-flex;gap:3px;">
  {%- for i in range(1, 6) -%}
  <span style="width:5px;height:11px;border-radius:1px;background:{% if i <= n %}{% if n >= 4 %}var(--amber){% else %}var(--primary){% endif %}{% else %}var(--surface-3){% endif %};{% if i <= n %}box-shadow:var(--glow-sm);{% endif %}"></span>
  {%- endfor -%}
</span>
{%- endmacro %}

{# Job-creation wizard progress stepper — ported from wizard.jsx Stepper.
   `current` is one of: setup, hashfile, notifications, tasks, summary. #}
{# `alert_hashes` (or current=='hashselect') reveals the conditional "Alert Hashes"
   step; step numbers are generated by a CSS counter so hiding/showing it auto-renumbers
   Tasks/Summary (see .wstep / .wstep-num in phosphor-app.css). #}
{% macro wizard_stepper(current, alert_hashes=false) -%}
{%- set steps = [('setup','Job Setup','jobs',false),('hashfile','Hashfile','file',false),('notifications','Notifications','bell',false),('hashselect','Alert Hashes','key',true),('tasks','Tasks','task',false),('summary','Summary','checkCircle',false)] -%}
{%- set order = ['setup','hashfile','notifications','hashselect','tasks','summary'] -%}
{%- set cur = order.index(current) if current in order else 0 -%}
<div class="wizard-steps{% if alert_hashes or current == 'hashselect' %} show-alert{% endif %}">
  {%- for key, label, ico, cond in steps -%}
    {%- set i = loop.index0 -%}
    {%- set state = 'done' if i < cur else ('active' if i == cur else 'todo') -%}
    <div class="wstep {{ state }}{% if cond %} wstep-cond{% endif %}">
      <div class="wstep-mark">{{ icon('check', size=18) if state == 'done' else icon(ico, size=18) }}</div>
      <div class="wstep-label"><span class="wstep-num"></span>{{ label }}</div>
    </div>
    {%- if not loop.last %}<div class="wstep-line {{ 'done' if i < cur else '' }}{% if cond %} wstep-cond{% endif %}"></div>{% endif -%}
  {%- endfor -%}
</div>
{%- endmacro %}