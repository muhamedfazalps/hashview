{% extends "layout.html.j2" %}
{% from "icons.html.j2" import icon %}
{% block title %}Dashboard · Hashview{% endblock %}
{% block content %}
<style>
/* Running-jobs task tables: slightly larger STATUS badges than the app default. */
.rj-tasks td .badge { font-size: 12px; padding: 4px 11px; }
.rj-tasks td .badge svg { width: 14px; height: 14px; }
.queue-tbl thead th { padding-top: 14px; padding-bottom: 14px; }
</style>

<div class="page-head">
    <div>
        <h1 class="page-title">Operations Dashboard</h1>
        <div class="page-sub">// recovery telemetry · live</div>
    </div>
    <a class="btn btn-primary" href="{{ url_for('jobs.jobs_add') }}">{{ icon('plus', size=15) }} New Job</a>
</div>

{# ---------- KPI row (live: /dashboard/summary) ---------- #}
<div id="dash-kpis" style="margin-bottom: var(--gap);">{% include "_dash_kpis.html.j2" %}</div>

{# ---------- Jobs: running + queue, directly under the KPI row (live: /dashboard/jobs) ---------- #}
<div id="dash-jobs" style="margin-bottom: var(--gap);">{% include "_dash_jobs.html.j2" %}</div>

{# ---------- Passwords recovered chart + live recovery feed (full width) ---------- #}
<div class="card" style="margin-bottom: var(--gap);">
    <div class="card-head"><span class="dot-led on"></span><h3>Passwords Recovered</h3><span class="mono" style="margin-left:auto;font-size:11px;color:var(--text-mute);">last 7 days</span></div>
    <div class="card-body">
        <div class="chart-wrap"><canvas id="chLine"></canvas></div>

        {# ---- live recovery feed, under the graph (live: /dashboard/recovery) ---- #}
        <div style="display:flex; align-items:center; gap:10px; margin:22px 0 2px; padding-top:16px; border-top:1px solid var(--border-soft);">
            <span class="dot-led on"></span>
            <h3 style="margin:0; font-size:12px; font-family:var(--mono); font-weight:600; letter-spacing:1.2px; text-transform:uppercase; color:var(--text-dim);">Live Recovery Feed</h3>
        </div>
        <div id="dash-recovery">{% include "_dash_recovery.html.j2" %}</div>
    </div>
</div>

{# ---------- Agent fleet (modal, opened from the "Agents online" KPI) ----------
   Inner content lives in _dash_fleet.html.j2 and is refreshed in place by
   /dashboard/fleet while the modal is open (the <dialog> shell stays put so its
   open/closed state survives the swap). #}
<dialog class="hv-dialog" id="agent-fleet-modal" style="max-width:840px; width:92vw;">
    <div id="dash-fleet">{% include "_dash_fleet.html.j2" %}</div>
</dialog>

{% endblock %}

{% block scripts %}
<script src="{{ url_for('static', filename='js/chart.min.js') }}"></script>
<script>
(function () {
    // ---------- Passwords-recovered line chart ----------
    // Kept on window.hvChart so /dashboard/summary polls can update it in place.
    var css = getComputedStyle(document.documentElement);
    var primary = (css.getPropertyValue('--primary') || '#ffb53d').trim();
    var rgb = (css.getPropertyValue('--primary-rgb') || '255,181,61').trim();
    var grid = (css.getPropertyValue('--border') || '#1b2119').trim();
    var tick = (css.getPropertyValue('--text-mute') || '#515c4b').trim();
    var bg = (css.getPropertyValue('--bg') || '#060807').trim();
    var mono = "IBM Plex Mono, monospace";
    var el = document.getElementById('chLine');
    if (el && typeof Chart !== 'undefined') {
        var ctx = el.getContext('2d');
        var grad = ctx.createLinearGradient(0, 0, 0, 240);
        grad.addColorStop(0, 'rgba(' + rgb + ',0.28)');
        grad.addColorStop(1, 'rgba(' + rgb + ',0)');
        window.hvChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: {{ fig1_labels | safe }},
                datasets: [{
                    data: {{ fig1_values | safe }},
                    backgroundColor: grad,
                    borderColor: primary,
                    borderWidth: 2.4,
                    pointBackgroundColor: bg,
                    pointBorderColor: primary,
                    pointBorderWidth: 2,
                    pointRadius: 3,
                    pointHoverRadius: 5,
                    lineTension: 0,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                legend: { display: false },
                tooltips: {
                    backgroundColor: '#161a14', titleFontFamily: mono, bodyFontFamily: mono,
                    titleFontColor: tick, bodyFontColor: primary, borderColor: '#2a3525', borderWidth: 1,
                    displayColors: false,
                    callbacks: {
                        // Show e.g. "1,000 cracked": thousands-separated value + the word.
                        label: function (tooltipItem) {
                            var n = Number(tooltipItem.yLabel) || 0;
                            return n.toLocaleString('en-US') + ' cracked';
                        }
                    }
                },
                scales: {
                    xAxes: [{ gridLines: { color: grid, zeroLineColor: grid, drawBorder: false }, ticks: { fontColor: tick, fontFamily: mono, fontSize: 10 } }],
                    yAxes: [{ gridLines: { color: grid, zeroLineColor: grid, drawBorder: false }, ticks: { fontColor: tick, fontFamily: mono, fontSize: 10, beginAtZero: true, precision: 0 } }]
                }
            }
        });
    }

    // ---------- Live recovery feed: flash newly-arrived rows ----------
    // sessionStorage tracks which row keys we've already shown so only genuinely-new
    // entries flash (nothing flashes on the first view of the session). Re-run after
    // every feed swap.
    var STORE = 'hv_recovery_feed_seen';
    function markFreshRecoveryRows() {
        var body = document.getElementById('recovery-feed-body');
        if (!body) return;
        var prev = null;
        try { prev = JSON.parse(sessionStorage.getItem(STORE) || 'null'); } catch (e) {}
        var seen = prev ? new Set(prev) : null;
        var current = [];
        body.querySelectorAll('tr[data-key]').forEach(function (tr) {
            var k = tr.getAttribute('data-key');
            current.push(k);
            if (seen && !seen.has(k)) { tr.classList.add('feed-fresh'); }
        });
        try { sessionStorage.setItem(STORE, JSON.stringify(current)); } catch (e) {}
    }
    markFreshRecoveryRows();

    // ---------- Independent dashboard polling (no full-page reload) ----------
    // recovery feed: 5s · KPIs+chart: 15s · jobs/queue: 20s. Polling pauses while the
    // tab is hidden and catches up on return. GET-only, so no CSRF token is required.
    var GET = { headers: { 'X-Requested-With': 'fetch' } };

    function pollRecovery() {
        fetch('{{ url_for("main.dashboard_recovery") }}', GET)
            .then(function (r) { return r.ok ? r.text() : null; })
            .then(function (html) {
                if (html == null) return;
                var box = document.getElementById('dash-recovery');
                if (box) { box.innerHTML = html; markFreshRecoveryRows(); }
            })
            .catch(function () {});
    }

    function pollJobs() {
        fetch('{{ url_for("main.dashboard_jobs") }}', GET)
            .then(function (r) { return r.ok ? r.text() : null; })
            .then(function (html) {
                if (html == null) return;
                var box = document.getElementById('dash-jobs');
                if (!box) return;
                // Preserve which job cards the user has collapsed across the swap.
                var openState = {};
                box.querySelectorAll('details[data-job-id]').forEach(function (d) {
                    openState[d.getAttribute('data-job-id')] = d.open;
                });
                box.innerHTML = html;
                box.querySelectorAll('details[data-job-id]').forEach(function (d) {
                    var id = d.getAttribute('data-job-id');
                    if (id in openState) { d.open = openState[id]; }
                });
            })
            .catch(function () {});
    }

    function pollSummary() {
        fetch('{{ url_for("main.dashboard_summary") }}', GET)
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (data) {
                if (!data || data.status !== 'ok') return;
                var kpis = document.getElementById('dash-kpis');
                if (kpis && data.kpis_html) { kpis.innerHTML = data.kpis_html; }
                if (window.hvChart && data.chart) {
                    window.hvChart.data.labels = data.chart.labels;
                    window.hvChart.data.datasets[0].data = data.chart.values;
                    window.hvChart.update();
                }
            })
            .catch(function () {});
    }

    function pollFleet() {
        // Only refresh while the modal is open — no point querying agents for hidden content.
        var modal = document.getElementById('agent-fleet-modal');
        if (!modal || !modal.open) return;
        fetch('{{ url_for("main.dashboard_fleet") }}', GET)
            .then(function (r) { return r.ok ? r.text() : null; })
            .then(function (html) {
                if (html == null) return;
                var box = document.getElementById('dash-fleet');
                if (box) { box.innerHTML = html; }
            })
            .catch(function () {});
    }

    // Opening the fleet modal (from the "Agents online" KPI) shows current data
    // immediately, then pollFleet keeps it fresh while open. Global so it survives
    // KPI re-renders from /dashboard/summary.
    window.hvOpenFleet = function () {
        var modal = document.getElementById('agent-fleet-modal');
        if (modal) { modal.showModal(); pollFleet(); }
    };

    var timers = [];
    function startPolling() {
        stopPolling();
        timers.push(setInterval(pollRecovery, 5000));
        timers.push(setInterval(pollSummary, 15000));
        timers.push(setInterval(pollJobs, 20000));
        timers.push(setInterval(pollFleet, 20000));
    }
    function stopPolling() {
        timers.forEach(clearInterval);
        timers = [];
    }
    document.addEventListener('visibilitychange', function () {
        if (document.hidden) {
            stopPolling();
        } else {
            pollRecovery(); pollSummary(); pollJobs(); pollFleet();
            startPolling();
        }
    });
    if (!document.hidden) { startPolling(); }
})();
</script>
{% endblock %}
