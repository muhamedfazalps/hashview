{% extends "layout.html.j2" %}
{% from "icons.html.j2" import icon %}
{% block title %}Hash Files · Hashview{% endblock %}
{% block content %}

<div class="page-head">
    <div>
        <h1 class="page-title">Hash Files</h1>
        <div class="page-sub">// Hash files are assigned to a single customer. Deleting a hash file removes it from the customer, but cracked hashes remain in the database.</div>
    </div>
</div>

<div class="card">
    {% if customers %}
    <table class="tbl">
        <thead>
            <tr>
                <th>Customer</th>
                <th>Hash File Name</th>
                <th>Hash Type</th>
                <th class="center">Crack Rate</th>
                <th>Uploaded At</th>
                <th class="center">Control</th>
            </tr>
        </thead>
        <tbody>
            {% for customer in customers %}
                <tr>
                    <td style="font-weight:500;">{{ customer.name }}</td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                </tr>
                {% for hashfile in hashfiles %}
                    {% if hashfile.customer_id == customer.id %}
                        <tr>
                            <td></td>
                            <td style="font-weight:500;">{{ hashfile.name }}</td>
                            <td class="mono" style="color:var(--text-dim);">{{ hash_type_dict[hashfile.id] }}</td>
                            <td class="center"><span class="badge dim">{{ cracked_rate[hashfile.id] }}</span></td>
                            <td class="mono" style="color:var(--text-mute);font-size:11.5px;">{{ hashfile.uploaded_at }}</td>
                            <td class="center">
                                <div style="display:flex; gap:4px; justify-content:center;">
                                    <a class="icon-btn" href="/analytics/download?type=found&customer_id={{customer.id}}&hashfile_id={{hashfile.id}}" title="Download">{{ icon('download', size=15) }}</a>
                                    <a class="icon-btn" href="/analytics?customer_id={{customer.id}}&hashfile_id={{hashfile.id}}" title="Analytics">{{ icon('chart', size=15) }}</a>
                                    <button type="button" class="icon-btn" title="Info" onclick="document.getElementById('info-{{ hashfile.id }}').showModal()">{{ icon('info', size=15) }}</button>
                                    <button type="button" class="icon-btn act-del" title="Delete" onclick="document.getElementById('del-{{ hashfile.id }}').showModal()">{{ icon('trash', size=15) }}</button>
                                </div>
                            </td>
                        </tr>
                    {% endif %}
                {% endfor %}
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <div class="card-body" style="text-align:center; padding:48px 24px;">
        <div class="mono" style="color:var(--text-dim);">No hash files found.</div>
    </div>
    {% endif %}
</div>

{# ---- per-hashfile modals (native <dialog>, no framework) ---- #}
{% for hashfile in hashfiles %}
<dialog class="hv-dialog" id="info-{{ hashfile.id }}">
    <div class="hv-dialog-head"><h3>Info: {{ hashfile.name }}</h3><button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button></div>
    <div class="hv-dialog-body">
        <dl class="kv">
            <dt>Associated Jobs</dt>
            <dd>
                {% set associated_jobs = namespace(value=0) %}
                {% for job in jobs %}
                    {% if job.hashfile_id == hashfile.id %}
                        {% set associated_jobs.value = 1 %}
                        {{ job.name }}<br>
                    {% endif %}
                {% endfor %}
                {% if associated_jobs.value == 0 %}
                    <i>none</i>
                {% endif %}
            </dd>
        </dl>
    </div>
    <div class="hv-dialog-foot"><button class="btn" onclick="this.closest('dialog').close()">Close</button></div>
</dialog>

<dialog class="hv-dialog" id="del-{{ hashfile.id }}">
    <div class="hv-dialog-head"><h3>Delete: {{ hashfile.name }}?</h3><button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button></div>
    <div class="hv-dialog-body">This will permanently delete the hashfile. Cracked hashes disassociated with any customer or username will be retained. Are you sure you want to continue?</div>
    <div class="hv-dialog-foot">
        <button class="btn" onclick="this.closest('dialog').close()">Close</button>
        <form action="{{ url_for('hashfiles.hashfiles_delete', hashfile_id=hashfile.id) }}" method="POST" style="display:inline;">
            <button class="btn btn-danger" type="submit">Delete</button>
        </form>
    </div>
</dialog>
{% endfor %}

{% endblock content %}
