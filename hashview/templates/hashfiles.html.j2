{% extends "layout.html.j2" %}
{% from "macros.html.j2" import icon, status_badge %}
{% block title %}Hash Files · Hashview{% endblock %}
{% block content %}
<style>
.hv-dl-opt { transition: border-color .15s, background .15s; }
.hv-dl-opt:hover { border-color: var(--primary-dim); background: rgba(var(--primary-rgb), 0.06); }
</style>

<div class="page-head">
    <div>
        <h1 class="page-title">Hashfiles</h1>
        <div class="page-sub">// {{ hashfiles|length }} files · {{ "{:,}".format(total_recovered) }}/{{ "{:,}".format(total_hashes) }} recovered</div>
    </div>
</div>

{# ---------- summary KPI cards ---------- #}
<div class="grid" style="grid-template-columns: repeat(3, 1fr); margin-bottom: var(--gap);">
    <div class="kpi">
        <div class="kpi-label">{{ icon('hash', size=13) }} Total Hashes</div>
        <div class="kpi-value">{{ "{:,}".format(total_hashes) }}</div>
    </div>
    <div class="kpi">
        <div class="kpi-label">{{ icon('key', size=13) }} Recovered</div>
        <div class="kpi-value accent">{{ "{:,}".format(total_recovered) }}</div>
    </div>
    <div class="kpi">
        <div class="kpi-label">{{ icon('chart', size=13) }} Overall Rate</div>
        <div class="kpi-value">{{ overall_rate }}<span style="font-size:16px;color:var(--text-dim);">%</span></div>
    </div>
</div>

<div class="card">
    {# ---- filter bar: magnifying glass beside the input, top-right of the card ---- #}
    <div class="card-head" style="justify-content:flex-end;">
        <span style="color:var(--text-mute); display:inline-flex;">{{ icon('search', size=16) }}</span>
        <input type="text" id="hf-filter" class="input" style="width:260px; flex:none;" placeholder="filter by hashfile or customer…" autocomplete="off" oninput="hvFilterHashfiles(this.value)">
    </div>
    {% if hashfiles %}
    <table class="tbl">
        <thead>
            <tr>
                <th>Hashfile</th>
                <th class="center">Type</th>
                <th>Customer</th>
                <th class="center">Hashes</th>
                <th class="center">Recovered</th>
                <th>Uploaded</th>
                <th class="center" style="width:140px;">Control</th>
            </tr>
        </thead>
        <tbody id="hf-tbody">
            {% for hashfile in hashfiles %}
            {% set st = hashfile_stats.get(hashfile.id) if hashfile_stats is defined else none %}
            <tr data-name="{{ hashfile.name|lower }}{% for c in customers %}{% if c.id == hashfile.customer_id %} {{ c.name|lower }}{% endif %}{% endfor %}">
                <td style="font-weight:500;">
                    <span style="display:inline-flex; align-items:center; gap:9px;">
                        <span style="color:var(--text-mute); display:inline-flex;">{{ icon('file', size=16) }}</span>
                        {{ hashfile.name }}
                    </span>
                </td>
                <td class="center"><span class="badge cyan">{{ hash_type_dict[hashfile.id] }}</span></td>
                <td style="color:var(--text-dim);">{% for c in customers %}{% if c.id == hashfile.customer_id %}{{ c.name }}{% endif %}{% endfor %}</td>
                <td class="center num">{{ "{:,}".format(st.total) if st else 0 }}</td>
                <td class="center">
                    {% if st and st.total %}
                    <div class="mono num" style="font-size:12.5px; white-space:nowrap;">
                        <span style="color:{{ 'var(--primary)' if st.cracked else 'var(--text-mute)' }};{% if st.cracked %}text-shadow:var(--glow-text);{% endif %}">{{ "{:,}".format(st.cracked) }}</span>
                        <span style="color:var(--text-mute);">({{ st.pct }}%)</span>
                    </div>
                    <div style="height:3px; width:84px; margin:6px auto 0; border-radius:2px; background:var(--surface-3); overflow:hidden;">
                        <div style="height:100%; width:{{ st.pct }}%; background:linear-gradient(90deg,var(--primary-deep),var(--primary)); box-shadow:var(--glow-sm);"></div>
                    </div>
                    {% else %}
                    <span style="color:var(--text-mute);">—</span>
                    {% endif %}
                </td>
                <td class="mono" style="color:var(--text-mute);font-size:11.5px;">{{ hashfile.uploaded_at }}</td>
                <td class="center">
                    <div style="display:flex; gap:4px; justify-content:center;">
                        <button type="button" class="icon-btn" title="Download" onclick="document.getElementById('dl-{{ hashfile.id }}').showModal()">{{ icon('download', size=15) }}</button>
                        <a class="icon-btn" href="/analytics?customer_id={{hashfile.customer_id}}&hashfile_id={{hashfile.id}}" title="Analytics">{{ icon('chart', size=15) }}</a>
                        <button type="button" class="icon-btn" title="Info" onclick="document.getElementById('info-{{ hashfile.id }}').showModal()">{{ icon('info', size=15) }}</button>
                        <button type="button" class="icon-btn act-del" style="color:var(--red); border-color:var(--red-dim);" title="Delete" onclick="document.getElementById('del-{{ hashfile.id }}').showModal()">{{ icon('trash', size=15) }}</button>
                    </div>
                </td>
            </tr>
            {% endfor %}
            <tr id="hf-no-match" style="display:none;"><td colspan="7" style="text-align:center; padding:28px 16px; color:var(--text-mute);" class="mono">No hashfiles match that filter.</td></tr>
        </tbody>
    </table>
    {% else %}
    <div class="card-body" style="text-align:center; padding:48px 24px;">
        <div class="mono" style="color:var(--text-dim);">No hash files found.</div>
    </div>
    {% endif %}
</div>

<script>
function hvFilterHashfiles(q){
    q = (q || '').trim().toLowerCase();
    var shown = 0;
    document.querySelectorAll('#hf-tbody tr[data-name]').forEach(function(tr){
        var hit = !q || (tr.getAttribute('data-name') || '').indexOf(q) !== -1;
        tr.style.display = hit ? '' : 'none';
        if (hit) shown++;
    });
    var none = document.getElementById('hf-no-match');
    if (none) none.style.display = shown === 0 ? '' : 'none';
}
</script>

{# ---- per-hashfile modals (native <dialog>, no framework) ---- #}
{% for hashfile in hashfiles %}
<dialog class="hv-dialog" id="info-{{ hashfile.id }}" style="max-width:760px; width:94vw;">
    {% set hfjobs = hashfile_jobs.get(hashfile.id, []) if hashfile_jobs is defined else [] %}
    {% set st = hashfile_stats.get(hashfile.id) if hashfile_stats is defined else none %}
    <div class="hv-dialog-head">
        {{ icon('file', size=16) }}
        <div style="line-height:1.2;">
            <h3 style="margin:0;">{{ hashfile.name }}</h3>
            <div class="mono" style="font-size:10px; letter-spacing:0.5px; text-transform:uppercase; color:var(--text-mute); margin-top:3px;">job history · {{ hfjobs|length }} job{{ '' if hfjobs|length == 1 else 's' }} run against this file</div>
        </div>
        <button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button>
    </div>
    <div class="hv-dialog-body" style="max-height:70vh; overflow-y:auto;">
        {# hashfile summary strip #}
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:8px;">
            <span class="badge cyan">{{ hash_type_dict[hashfile.id] }}</span>
            <span style="color:var(--text-dim);">{% for c in customers %}{% if c.id == hashfile.customer_id %}{{ c.name }}{% endif %}{% endfor %}</span>
            <span class="mono" style="margin-left:auto; font-size:12.5px;">{% if st %}<span style="color:var(--primary); text-shadow:var(--glow-text);">{{ "{:,}".format(st.cracked) }}</span><span style="color:var(--text-mute);"> / {{ "{:,}".format(st.total) }} recovered</span>{% endif %}</span>
            <span style="display:inline-block; text-align:center; line-height:1;">
                <span class="mono" style="font-size:24px; color:var(--primary); text-shadow:var(--glow-text);">{{ st.pct if st else 0 }}<span style="font-size:12px;">%</span></span>
                <span class="mono" style="display:block; font-size:9px; letter-spacing:1px; color:var(--text-mute); margin-top:2px;">CRACKED</span>
            </span>
        </div>
        <div style="height:4px; border-radius:2px; background:var(--surface-3); overflow:hidden; margin-bottom:18px;">
            <div style="height:100%; width:{{ st.pct if st else 0 }}%; background:linear-gradient(90deg,var(--primary-deep),var(--primary)); box-shadow:var(--glow-sm);"></div>
        </div>

        {# per-job history #}
        {% if hfjobs %}
        {% for j in hfjobs %}
        <div class="card" style="margin-bottom:12px; padding:14px 16px;">
            <div style="display:flex; align-items:center; gap:10px;">
                <span class="dot-led {% if j.status == 'Running' %}run{% elif j.status == 'Completed' %}on{% elif j.status == 'Canceled' %}off{% else %}idle{% endif %}"></span>
                <span class="mono" style="color:var(--text-mute);">#{{ j.id }}</span>
                <span style="font-weight:600; color:var(--text);">{{ j.name }}</span>
                <span style="margin-left:auto;">{{ status_badge(j.status) }}</span>
            </div>
            <div style="display:flex; align-items:center; gap:20px; margin-top:11px; font-family:var(--mono); font-size:11.5px; color:var(--text-mute);">
                <span style="display:inline-flex; align-items:center; gap:6px;">{{ icon('users', size=14) }} {{ j.owner }}</span>
                <span style="display:inline-flex; align-items:center; gap:6px;">{{ icon('task', size=14) }} {{ j.tasks }} tasks</span>
                <span style="display:inline-flex; align-items:center; gap:6px;">{{ icon('clock', size=14) }} {{ j.runtime }}</span>
                <span style="margin-left:auto;">{{ j.date.strftime('%b %d %H:%M') if j.date else '—' }}</span>
            </div>
        </div>
        {% endfor %}
        {% else %}
        <div class="mono" style="color:var(--text-mute); padding:8px 0 14px;">No jobs have run against this hashfile.</div>
        {% endif %}
    </div>
    <div class="hv-dialog-foot">
        {% set completed = hfjobs | selectattr('status', 'equalto', 'Completed') | list | length %}
        <span class="mono" style="font-size:11.5px; color:var(--text-mute); margin-right:auto;">{{ completed }} completed · {{ hfjobs|length }} total</span>
        <button class="btn" onclick="this.closest('dialog').close()">Close</button>
    </div>
</dialog>

<dialog class="hv-dialog" id="dl-{{ hashfile.id }}" style="max-width:540px; width:94vw;">
    <div class="hv-dialog-head">
        {{ icon('download', size=16) }}
        <div style="line-height:1.2;">
            <h3 style="margin:0;">Download {{ hashfile.name }}</h3>
            <div class="mono" style="font-size:10px; letter-spacing:0.5px; text-transform:uppercase; color:var(--text-mute); margin-top:3px;">choose an export format</div>
        </div>
        <button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close" style="margin-left:auto;">{{ icon('x', size=15) }}</button>
    </div>
    <div class="hv-dialog-body" style="display:flex; flex-direction:column; gap:10px;">
        {% set st = hashfile_stats.get(hashfile.id) if hashfile_stats is defined else none %}
        <a class="card hv-dl-opt" href="{{ url_for('hashfiles.hashfiles_download', hashfile_id=hashfile.id, fmt='hashes') }}" onclick="this.closest('dialog').close()" style="display:block; padding:12px 14px; text-decoration:none;">
            <div style="color:var(--text); font-weight:500;">{{ icon('hash', size=14) }} Hashes only</div>
            <div class="field-hint" style="margin-top:3px;">Every hash, no plaintext — feed straight back into hashcat.</div>
        </a>
        <a class="card hv-dl-opt" href="{{ url_for('hashfiles.hashfiles_download', hashfile_id=hashfile.id, fmt='all') }}" onclick="this.closest('dialog').close()" style="display:block; padding:12px 14px; text-decoration:none;">
            <div style="color:var(--text); font-weight:500;">{{ icon('list', size=14) }} All hashes (uncracked + cracked&hairsp;:&hairsp;plain)</div>
            <div class="field-hint" style="margin-top:3px;">Uncracked shown as the hash; cracked shown as <span class="mono">hash:plain</span>.</div>
        </a>
        <a class="card hv-dl-opt" href="{{ url_for('hashfiles.hashfiles_download', hashfile_id=hashfile.id, fmt='cracked') }}" onclick="this.closest('dialog').close()" style="display:block; padding:12px 14px; text-decoration:none;">
            <div style="color:var(--text); font-weight:500;">{{ icon('key', size=14) }} Cracked hashes with plaintext</div>
            <div class="field-hint" style="margin-top:3px;">Only recovered hashes, as <span class="mono">hash:plain</span>{% if st %} · {{ "{:,}".format(st.cracked) }} cracked{% endif %}.</div>
        </a>
        <a class="card hv-dl-opt" href="{{ url_for('hashfiles.hashfiles_download', hashfile_id=hashfile.id, fmt='plains') }}" onclick="this.closest('dialog').close()" style="display:block; padding:12px 14px; text-decoration:none;">
            <div style="color:var(--text); font-weight:500;">{{ icon('key', size=14) }} Plaintext only</div>
            <div class="field-hint" style="margin-top:3px;">Just the recovered passwords, one per line.</div>
        </a>
    </div>
    <div class="hv-dialog-foot">
        <button class="btn" onclick="this.closest('dialog').close()">Close</button>
    </div>
</dialog>

<dialog class="hv-dialog" id="del-{{ hashfile.id }}">
    <div class="hv-dialog-head"><h3>Delete: {{ hashfile.name }}?</h3><button class="icon-btn" onclick="this.closest('dialog').close()" aria-label="Close">{{ icon('x', size=15) }}</button></div>
    <div class="hv-dialog-body">This will permanently delete the hashfile. Cracked hashes disassociated with any customer or username will be retained. Are you sure you want to continue?</div>
    <div class="hv-dialog-foot">
        <button class="btn" onclick="this.closest('dialog').close()">Close</button>
        <form action="{{ url_for('hashfiles.hashfiles_delete', hashfile_id=hashfile.id) }}" method="POST" style="display:inline;">
            <button class="btn btn-danger" type="submit">Delete</button>
        </form>
    </div>
</dialog>
{% endfor %}

{% endblock content %}
